@helper GetSuccessMessage()
{
    if (string.Equals((string)ViewContext.RouteData.Values["action"], "edit", StringComparison.OrdinalIgnoreCase))
    {
        @("更新成功")
    }
    else
    {
        @("添加成功")
    }
}