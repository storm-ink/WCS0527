@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Wms.Material>


<table border="1" cellpadding="1" cellspacing="4">
        <tr>
            <th>
                名称
            </th>
            <th>
                编码
            </th>
            <th>
                条码
            </th>

            <th>
                创建日期
            </th>

            <th>
                备注
            </th>
            <th>
                主单位
            </th>
            <th></th>
        </tr>
    
    @foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Code)
            </td>  
            <td>
                @Html.DisplayFor(modelItem => item.Barcode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MainUnit)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Comments)
            </td>
            <td>
                @Html.ActionLink("编辑", "Edit", new { id=item.Id }) |
                @Html.ActionLink("删除", "Delete", new { id = item.Id }, new { @class = "delete" })

            </td>
        </tr>
    }
    

</table>

    <p>
        @Html.ActionLink("新建", "Create")
    </p>


@if (Model.Count() > 0)
{
    <span>一共有 @Model.TotalItemCount 个记录</span>
    @Html.PagedListPager( this.Model, pageIndex => Url.Action("Index", new { pageIndex }) )
       
}
