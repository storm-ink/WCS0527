using System;
using System.Data;
using System.IO;
using System.Windows.Forms;

namespace Gensong
{
    /// <summary>报警信息</summary>
    public class Alarm
    {
        /// <summary>错误码 配置数据</summary>
        public static DataSet dsAlarm;

        /// <summary>设置错误码相关信息</summary>
        public static void SetErrorInfo(string sECode, ref Label lblECode, ref Label lblEName, ref Label lblDescription, ref Label lblSolution)
        {
            if (lblECode.Text == sECode) return;

            if (sECode != "0000")
            {
                lblECode.Text = sECode;

                DataRow[] arr = dsAlarm.Tables["ErrorCode"].Select(string.Format("{0}='{1}'", "EID", sECode));
                if (arr.Length > 0)
                {
                    lblEName.Text = Convert.ToString(arr[0]["EName"]);
                    lblDescription.Text = ReadErrorInfo(EError.Description, Convert.ToString(arr[0]["DID"]));
                    lblSolution.Text = ReadErrorInfo(EError.Solution, Convert.ToString(arr[0]["SID"]));
                }
                else
                {
                    lblEName.Text = lblDescription.Text = lblSolution.Text = string.Empty;
                }
            }
            else
            {
                lblECode.Text = lblEName.Text = lblDescription.Text = lblSolution.Text = string.Empty;
            }
        }
        /// <summary>读错误码相关信息</summary>
        public static string ReadErrorInfo(string sECode)
        {
            DataRow[] arr = dsAlarm.Tables["ErrorCode"].Select(string.Format("{0}='{1}'", "EID", sECode));

            return arr.Length > 0 ? Convert.ToString(arr[0]["EName"]) : sECode;
        }
        /// <summary>读错误码相关信息</summary>
        private static string ReadErrorInfo(EError eError, string sValue)
        {
            try
            {
                if (eError == EError.Description)
                    return Convert.ToString(dsAlarm.Tables["Description"].Select(string.Format("{0}='{1}'", "DID", sValue))[0]["DName"]);
                else if (eError == EError.Solution)
                    return Convert.ToString(dsAlarm.Tables["Solution"].Select(string.Format("{0}='{1}'", "SID", sValue))[0]["SName"]);
                else
                    return "";
            }
            catch //(Exception ex)
            {
                return "";
            }
        }

        /// <summary> 错误信息</summary>
        enum EError
        {
            /// <summary>错误码 对应的错误名</summary>
            Name,
            /// <summary>错误码 对应的错误描述</summary>
            Description,
            /// <summary>错误码 对应的错误处理</summary>
            Solution
        }
    }
}
