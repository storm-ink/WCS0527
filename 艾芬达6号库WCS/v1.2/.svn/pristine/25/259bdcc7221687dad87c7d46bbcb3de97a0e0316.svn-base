using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;

namespace Client.SingleForkCrane
{
    /// <summary>
    /// 报警信息
    /// </summary>
    public class Alarm
    {
        /// <summary>
        /// 报警码
        /// </summary>
        public virtual Int32 Code { get; set; }
        /// <summary>
        /// 名称
        /// </summary>
        public virtual String Name { get; set; }
        /// <summary>
        /// 报警类型
        /// </summary>
        public virtual String Type { get; set; }
    }
}
