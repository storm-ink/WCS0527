  </class>
  <database-object>
    <create>
      <![CDATA[      
      CREATE TABLE [dbo].[ConveyorLocationTasks](
	      [Id] [int] NOT NULL PRIMARY KEY NONCLUSTERED,
        [LogId] [int] NOT NULL,
	      [ProjectId] [int] NOT NULL,
        [CreatedAt] [datetime2](7) NULL,
        [LongDate] [datetime2](7) NULL,
        [Version] [int] NOT NULL,
	      [Name] [nvarchar](255) NOT NULL,
        
	      [PosNo] [int] NULL,
	      [TaskNo] [int] NULL,
	      [TUID] [int] NULL,
	      [Str_Rcv_X] [bit] NULL,
