      ) ON [PRIMARY]
      ]]>
    </create>
    <drop>
      <![CDATA[
      IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[ConveyorLocationTasks]') AND type in (N'U'))
