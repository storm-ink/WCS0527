@model Wms.Material


@using (Ajax.BeginForm(new AjaxOptions { UpdateTargetId = "form_container", OnBegin = "showTip", OnComplete = "hideTip" }))
{
        @Html.ValidationSummary(true)
    
        <fieldset>
            <legend>物料</legend>
    
            @Html.HiddenFor(model => model.Id)
            @Html.HiddenFor(model => model.Version)

    
    
            <div class="editor-label">
                @Html.LabelFor(model => model.Name)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.Name)
                @Html.ValidationMessageFor(model => model.Name)
            </div>
    
            <div class="editor-label">
                @Html.LabelFor(model => model.Barcode)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.Barcode)
                @Html.ValidationMessageFor(model => model.Barcode)
            </div>
    
            <div class="editor-label">
                @Html.LabelFor(model => model.Code)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.Code)
                @Html.ValidationMessageFor(model => model.Code)
            </div>
    
            <div class="editor-label">
                @Html.LabelFor(model => model.Weight)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.Weight)
                @Html.ValidationMessageFor(model => model.Weight)
            </div>


    
            <div class="editor-label">
                @Html.LabelFor(model => model.MainUnit)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.MainUnit)
                @Html.ValidationMessageFor(model => model.MainUnit)
            </div>
        
            <div class="editor-label">
                @Html.LabelFor(model => model.Comments)
            </div>
            <div class="editor-field">
                @Html.EditorFor(model => model.Comments)
                @Html.ValidationMessageFor(model => model.Comments)
            </div>

           <p>
                <input type="submit" value="保存" />
            </p>
        </fieldset>
    
    }
