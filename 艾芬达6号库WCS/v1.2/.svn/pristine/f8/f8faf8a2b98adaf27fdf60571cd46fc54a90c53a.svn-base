<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://tempuri.org/" elementFormDefault="qualified" targetNamespace="http://tempuri.org/" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:import namespace="http://schemas.datacontract.org/2004/07/DC2" />
  <xs:import namespace="http://schemas.datacontract.org/2004/07/Wms" />
  <xs:element name="Request">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q1="http://schemas.datacontract.org/2004/07/DC2" minOccurs="0" name="requestInfo" nillable="true" type="q1:WcsRequestInfo" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="RequestResponse">
    <xs:complexType>
      <xs:sequence />
    </xs:complexType>
  </xs:element>
  <xs:element name="CompleteTask">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q2="http://schemas.datacontract.org/2004/07/DC2" minOccurs="0" name="taskInfo" nillable="true" type="q2:WcsTaskInfo" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="CompleteTaskResponse">
    <xs:complexType>
      <xs:sequence />
    </xs:complexType>
  </xs:element>
  <xs:element name="RequestingTask">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q3="http://schemas.datacontract.org/2004/07/DC2" minOccurs="0" name="requestInfo" nillable="true" type="q3:WcsRequestInfo" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="RequestingTaskResponse">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q4="http://schemas.datacontract.org/2004/07/Wms" minOccurs="0" name="RequestingTaskResult" nillable="true" type="q4:IDataModelBase.InvokeMsg" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="TaskErrorAndRequestNewEndPoint">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q5="http://schemas.datacontract.org/2004/07/DC2" minOccurs="0" name="wcsRequestCurrentLocation" nillable="true" type="q5:WcsRequestCurrentLocation" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="TaskErrorAndRequestNewEndPointResponse">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q6="http://schemas.datacontract.org/2004/07/Wms" minOccurs="0" name="TaskErrorAndRequestNewEndPointResult" nillable="true" type="q6:IDataModelBase.InvokeMsg" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="CompletingTask">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q7="http://schemas.datacontract.org/2004/07/DC2" minOccurs="0" name="taskInfo" nillable="true" type="q7:WcsTaskInfo" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="CompletingTaskResponse">
    <xs:complexType>
      <xs:sequence>
        <xs:element xmlns:q8="http://schemas.datacontract.org/2004/07/Wms" minOccurs="0" name="CompletingTaskResult" nillable="true" type="q8:IDataModelBase.InvokeMsg" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>