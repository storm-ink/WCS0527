using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Drawing;
using System.Linq;
using System.Runtime.Serialization;
using System.Text;
using System.Windows.Forms;
using Wcs.Client.Interfaces.Task;
using Wcs.Client.App.Elements.UIEditor;

namespace Wcs.Client.App.Elements
{
    [Description("任务据源")]
    [Serializable]
    public class TaskDataSource:Element,Wcs.Client.Interfaces.Task.ITaskService,System.Runtime.Serialization.ISerializable,IWarningContainer
    {
        Int32 m_Interval;

        StringFormat sf;

        public TaskDataSource(Editor editor)
            : base(editor)
        {
            Init();
        }

        public TaskDataSource(SerializationInfo info, StreamingContext context)
            : base(info, context)
        {
            Init();
            this.ConfigurationName = (string)info.GetValue("ConfigurationName", typeof(string));
            this.Interval = (Int32)info.GetValue("Interval", typeof(Int32));
        }

        [Description("终结点配置名称"), Category("行为"),
        EditorAttribute(typeof(ServiceEndPointConfigurationNameEditor), typeof(System.Drawing.Design.UITypeEditor))]
        public String ConfigurationName { get; set; }

        public Int32 Interval
        {
            get
            {
                return m_Interval;
            }
            set
            {
                if (value < 500)
                {
                    throw new InvalidOperationException("激活间隔时间必须大于等于 500ms");
                }
                m_Interval = value;
            }
        }

        [Browsable(false)]
        public Task[] Tasks { get; private set; }

        public override void Draw(System.Drawing.Graphics graphics)
        {
            if (Editor.IsDesign)
            {
                base.Draw(graphics);

                graphics.DrawRectangles(Pens.Red, new RectangleF[] { this.Rectangle });
                graphics.DrawString("任务数据源", Control.DefaultFont, new SolidBrush(Color.Red), this.Rectangle, sf);
            }
        }

        public override void GetObjectData(System.Runtime.Serialization.SerializationInfo info, System.Runtime.Serialization.StreamingContext context)
        {
            info.AddValue("Interval", this.Interval);
            info.AddValue("ConfigurationName", this.ConfigurationName);

            base.GetObjectData(info, context);
        }

        void Init()
        {
            this.Size = new System.Drawing.SizeF(50, 50);
            sf = new StringFormat();
            sf.Alignment = StringAlignment.Center;
            sf.LineAlignment = StringAlignment.Center;
            Interval = 1000;
            this.Tasks = new Task[0];

            System.Threading.ThreadPool.QueueUserWorkItem((stat) =>
            {
                Proc();
            });
        }
        void Proc()
        {
            while (true)
            {
                System.Threading.Thread.Sleep(Interval);

                if (Editor.IsDesign)
                {
                    continue;
                }

                if (String.IsNullOrWhiteSpace(this.ConfigurationName))
                {
                    continue;
                }

                TaskServiceClient client = null;
                try
                {
                    client = new TaskServiceClient(this.ConfigurationName);

                    client.Open();

                    Tasks = client.GetTasks();
                   
                }
                catch (Exception ex)
                {
                    Console.WriteLine(ex);

                    Tasks = new Task[0];
                    if (client != null)
                    {
                        client.Abort();
                    }
                }
                finally
                {
                    if (client != null)
                    {
                        client.Close();
                        client = null;
                    }
                }
            }
        }

        #region ITaskService
        public string[] AllOperations()
        {
            var client = new TaskServiceClient(this.ConfigurationName);
            try
            {
                client.Open();

                return client.AllOperations();

            }
            catch (Exception)
            {
                client.Abort();

                throw;
            }
            finally
            {
                client.Close();
                client = null;
            }
        }

        public object Call(string name, object[] args)
        {
            var client = new TaskServiceClient(this.ConfigurationName);
            try
            {
                client.Open();

                return client.Call(name, args);

            }
            catch (Exception)
            {
                client.Abort();

                throw;
            }
            finally
            {
                client.Close();
                client = null;
            }
        }

