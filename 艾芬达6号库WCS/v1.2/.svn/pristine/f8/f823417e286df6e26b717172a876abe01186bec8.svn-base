            catch (Exception)
            {
                client.Abort();

                throw;
            }
            finally
            {
                client.Close();
                client = null;
            }
        }

        public void CompleteTask(int id)
        {
            var client = new TaskServiceClient(this.ConfigurationName);
            try
            {
                client.Open();

                client.CompleteTask(id);

            }
            catch (Exception)
            {
                client.Abort();

                throw;
            }
            finally
            {
                client.Close();
                client = null;
            }
        }

        public Task GetTask(String taskNo)
        {
            return Tasks
                .FirstOrDefault(x => String.Equals(taskNo, x.TaskCode, StringComparison.CurrentCultureIgnoreCase));
        }

        public Task GetTaskByEquipmentTaskId(Int32 equipmentTaskId)
        {
            var task= Tasks
                .FirstOrDefault(x => x.Movements.Any(m => m.EquipmentActions.Any(a => a.EquipmentTaskId == equipmentTaskId)));
            return task;
        }

        public Task[] GetTasks()
        {
            return this.Tasks;
        }

        public void ResumeTask(string taskNo)
        {
            var client = new TaskServiceClient(this.ConfigurationName);
            try
            {
                client.Open();

                client.ResumeTask(taskNo);

            }
            catch (Exception)
            {
                client.Abort();

                throw;
            }
            finally
            {
                client.Close();
                client = null;
            }
        }

        public void ResumeTaskWithCurrentLocation(string taskNo, string currentLocation)
        {
            var client = new TaskServiceClient(this.ConfigurationName);
            try
            {
                client.Open();

                client.ResumeTaskWithCurrentLocation(taskNo, currentLocation);

            }
            catch (Exception)
            {
                client.Abort();

                throw;
            }
            finally
            {
                client.Close();
                client = null;
            }
        }

        public void SuspendTask(string taskNo)
        {
