        }
        #endregion

        public override Element Clone()
        {
            TaskDataSource ds = new TaskDataSource(this.Editor);

            ds.ConfigurationName = this.ConfigurationName;
            ds.Interval = this.Interval;

            CloneProperties(ds);

            return ds;
        }


        public Warning[] GetWarings()
        {
            if (Tasks == null || Tasks.Length == 0)
            {
                return new Warning[0];
            }

            List<Warning> result = new List<Warning>();
            foreach (var item in Tasks.Where(x=>x.Status==TaskStatus.Error || x.Status==TaskStatus.Suspend))
            {
                Warning w = new Warning();
                w.DeviceName = string.Format("任务{0}",item.TaskCode);
                //w.DeviceType = "任务管理器";
                if (item.Status == TaskStatus.Suspend)
                {
                    w.Message = "已暂停";
                }
                else
                {
                    w.Message = "发生错误，已暂停。";
                }

                result.Add(w);
            }

            foreach (var item in Tasks)
            {
                double timeoutMinute = 5d;
                var actions = item.Movements.SelectMany(x => x.EquipmentActions)
                    .Where(x => x.Status == EquipmentActionStatus.Executing
                        && x.SentAt != null
                        && DateTime.Now.Subtract(x.SentAt.Value).TotalMinutes > timeoutMinute);

                foreach (var act in actions)
                {
                    Warning w = new Warning();
                    w.DeviceName = string.Format("任务{0}的设备任务{1}", item.TaskCode,act.EquipmentTaskId);
                    //w.DeviceType = "任务管理器";
                    w.Message = string.Format("已执行了 {0} 分钟，但仍未完成。", timeoutMinute.ToString("0.##"));

                    result.Add(w);
                }

            }

            return result.ToArray();
        }

        public override float WidthScale
        {
            get
            {
                return 1f;
            }
        }

        public override float HeightScale
        {
            get
            {
                return 1f;
            }
        }
    }
}
