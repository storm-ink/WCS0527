                _logger.Trace1(string.Format("本次放货目标位置为 {0}", toLocation), this);


                craneDevice.Putdown(new Wcs.Framework.LockerInfo(userName, ipAddress), toLocation, (Wcs.DefaultImpls.Crane.ForkDirection)fork1Direction, (Wcs.DefaultImpls.Crane.ForkDirection)fork2Direction);

