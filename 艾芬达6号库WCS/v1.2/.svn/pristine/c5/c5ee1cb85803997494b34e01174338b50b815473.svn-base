using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;

namespace Wcs.Client.App.Elements
{
    /// <summary>
    /// 绝对位置转换器
    /// 将传入的相对坐标转换为容器的绝对外位置
    /// </summary>
    public class AbsoluteTransform:Transform
    {
        public AbsoluteTransform(Element element)
            : base(element)
        {
        }
        public override float X(float x)
        {
            if (Element.Parent == null)
            {
                return this.Element.Editor.OriginPoint.X+x*this.Element.WidthScale;
            }
            else
            {
                var p = Element.Parent;
                float result = x;
                while (p != null)
                {
                    result += p.Left;
                    p = p.Parent;
                }

                return this.Element.Editor.OriginPoint.X + result * this.Element.WidthScale; ;
            }
        }

        public override float Y(float y)
        {
            if (Element.Parent == null)
            {
                return this.Element.Editor.OriginPoint.Y + y * this.Element.HeightScale;
            }
            else
            {
                var p = Element.Parent;
                float result = y;
                while (p != null)
                {
                    result += p.Top;
                    p = p.Parent;
                }
                return this.Element.Editor.OriginPoint.Y + result * this.Element.HeightScale;
            }
        }

        public override float W(float w)
        {
            return w * this.Element.WidthScale;
        }

        public override float H(float h)
        {
            return h*this.Element.HeightScale;
        }
    }
}
