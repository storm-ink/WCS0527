using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Diagnostics;
using System.Threading;
using System.Windows.Forms;

namespace Gensong
{
    public partial class Crane
    {
        /// <summary>
        /// 表示堆垛机可以执行的动作。command 模式的变形。
        /// </summary>
        private abstract class CraneAction
        {
            ///// <summary>
            ///// 获取一个值，该值指示此任务是否被打断。
            ///// </summary>
            //public Boolean WasBroken { get; protected set; }

            /// <summary>
            /// 获取执行此动作的堆垛机。
            /// </summary>
            public Crane Crane { get; private set; }

            /// <summary>
            /// 获取一个值，该值指示此 CraneAction 是否是子动作。子动作在完成时不会更新堆垛机的状态。
            /// </summary>
            public Boolean IsChildAction { get; private set; }

            protected CraneAction(Crane crane, Boolean isChildAction)
            {
                this.Crane = crane;
                this.IsChildAction = isChildAction;
            }

            public abstract void ExecuteStep();

            /// <summary>
            /// 获取或设置一个值，指示此动作是否已经开始执行。
            /// </summary>
            protected Boolean IsStarted { get; set; }

            /// <summary>
            /// 获取或设置一个值，指示此动作是否已经完成。
            /// </summary>
            public Boolean IsCompleted { get; protected set; }

            /// <summary>
            /// 在此动作已经完成时引发。
            /// </summary>
            public event EventHandler Completed;

            /// <summary>
            /// 在此动作执行之前引发。
            /// </summary>
            public event EventHandler Starting;

            ///// <summary>
            ///// 在此动作被打断后引发。
            ///// </summary>
            //public event EventHandler Broken;

            protected virtual void OnCompleted(EventArgs e)
            {
                if (Completed != null)
                {
                    Completed(this, e);
                }
            }

            protected virtual void OnStarting(EventArgs e)
            {
                if (Starting != null)
                {
                    Starting(this, e);
                }
            }



            ///// <summary>
            ///// 打断此动作。
            ///// </summary>
            //public void Break()
            //{
            //    this.WasBroken = true;
            //    OnBroken(EventArgs.Empty);
            //}

        }
    }
}
