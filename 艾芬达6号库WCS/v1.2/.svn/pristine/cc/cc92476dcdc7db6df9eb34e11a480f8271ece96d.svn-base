using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Linq;
using System.Runtime.Serialization;
using System.Text;

namespace Client.SingleForkCrane
{
    /// <summary>
    /// 位置水平方向的位置状态（左右位）
    /// </summary>
    [DataContract]
    public enum ForkHorizontalPosition
    {
        /// <summary>中位</summary>
        [Description("中位")]
        [EnumMember]
        中位 = 1,
        /// <summary>左位</summary>
        [Description("左")]
        [EnumMember]
        左位 = 2,
        /// <summary>左极限</summary>
        [Description("左极限")]
        [EnumMember]
        左极限 = 3,
        /// <summary>右位</summary>
        [Description("右")]
        [EnumMember]
        右位 = 4,
        /// <summary>右极限</summary>
        [Description("右极限")]
        [EnumMember]
        右极限 = 5,    
        /// <summary>左（外）</summary>
        [Description("左（外）")]
        [EnumMember]
        左外,
        /// <summary>左（外）极限</summary>
        [Description("左（外）极限")]
        [EnumMember]
        左外极限,
        /// <summary>右（外）</summary>
        [Description("右（外）")]
        [EnumMember]
        右外,
        /// <summary>右（外）极限</summary>
        [Description("右（外）极限")]
        [EnumMember]
        右外极限
    }
}
