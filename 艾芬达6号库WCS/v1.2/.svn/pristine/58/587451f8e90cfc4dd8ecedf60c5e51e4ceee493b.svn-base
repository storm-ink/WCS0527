using System;
using System.Collections.Generic;
using System.Linq;
using System.ServiceModel;
using System.Text;

namespace Wcs.Client.App
{
    public class TwoForkCraneServiceClient : ClientBase<Wcs.Client.Interfaces.TwoForkCrane.ITwoForksCraneService>, Wcs.Client.Interfaces.TwoForkCrane.ITwoForksCraneService
    {
        public TwoForkCraneServiceClient(String configurationName)
            : base(configurationName)
        {
        }

        public List<Interfaces.SingleForkCrane.CraneInfo> LoadCraneInfos()
        {
            return Channel.LoadCraneInfos();
        }

        public Dictionary<string, Interfaces.TwoForkCrane.LA> ReadStatus()
        {
            return Channel.ReadStatus();
        }

        public void BackToTheOrigin(string craneName, string userName, string ipAddress)
        {
            Channel.BackToTheOrigin(craneName,userName,ipAddress);
        }

        public void EmergencyStop(string craneName)
        {
            Channel.EmergencyStop(craneName);
        }

        public void CancelEmergencyStop(string craneName, string userName, string ipAddress)
        {
            Channel.CancelEmergencyStop(craneName, userName,ipAddress);
        }

        public void Move(string craneName, string userName, string ipAddress, int userColumn, int userLevel)
        {
            Channel.Move(craneName, userName, ipAddress, userColumn, userLevel);
        }

        public void Pick(string craneName, string userName, string ipAddress, Interfaces.SingleForkCrane.ForkDirection? fork1Direction, Interfaces.SingleForkCrane.ForkDirection? fork2Direction)
        {
            Channel.Pick(craneName, userName, ipAddress, fork1Direction, fork2Direction);
        }

        public void Putdown(string craneName, string userName, string ipAddress, Interfaces.SingleForkCrane.ForkDirection? fork1Direction, Interfaces.SingleForkCrane.ForkDirection? fork2Direction)
        {
            Channel.Putdown(craneName, userName, ipAddress, fork1Direction, fork2Direction);
        }

        public void Lock(string craneName, string userName, string ipAddress)
        {
            Channel.Lock(craneName, userName, ipAddress);
        }

        public void Unlock(string craneName, string userName, string ipAddress)
        {
            Channel.Unlock(craneName, userName, ipAddress);
        }

        public void Up(string craneName, string userName, string ipAddress)
        {
            Channel.Up(craneName, userName, ipAddress);
        }

        public void Down(string craneName, string userName, string ipAddress)
        {
            Channel.Down(craneName, userName, ipAddress);
        }

        public void Forward(string craneName, string userName, string ipAddress)
        {
            Channel.Forward(craneName, userName, ipAddress);
        }

        public void Back(string craneName, string userName, string ipAddress)
        {
            Channel.Back(craneName, userName, ipAddress);
        }

        public void ResetWarn(string craneName, string userName, string ipAddress)
        {
            Channel.ResetWarn(craneName, userName, ipAddress);
        }

        public object Call(string name, object[] args)
        {
            return Channel.Call(name, args);
        }

        public string[] AllOperations()
        {
            return Channel.AllOperations();
        }
    }
}
