@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Client.Logs.WcsLogDiagnosisData>
@{
    Layout = null;
}

<table class="log-entries" id="table" >
<tr>
    <th>时间</th>
    <th>日志名</th>
    <th>级别</th>
    <th>消息</th>
    <th>&nbsp;</th>
  
</tr>

@foreach (var item in Model)
{
<tr class="@item.Level.ToLower()">
    <td class="longDate">@item.LongDate.ToString("HH:mm:ss.fff")</td>
    <td>@item.Logger</td>
    <td>@item.Level</td>
    <td>@(item.Message)</td>
    <td>
    @Html.ActionLink("详细", "Details", new { id = @item.Id }, new { target="_blank" })
    @if (!String.IsNullOrWhiteSpace(item.Exception))
    {
        <a href="javascript:$('#tr_exception_@item.Id').toggle('fast');void(0);">异常</a>
    }

    </td>
</tr>
if (!String.IsNullOrWhiteSpace(item.Exception))
{
<tr id="tr_exception_@item.Id" style="display:none;">
    <td colspan="6">
    <pre>@item.Exception</pre>
</td>
</tr>
}

}
</table>



@if (Model.Count() > 0)
{
    @Html.PagedListPager(this.Model, pageIndex => Url.Action("Index", new { pageIndex }), new PagedListRenderOptions { DisplayItemSliceAndTotal = true, ItemSliceAndTotalFormat = "共 {2} 个" })
}

