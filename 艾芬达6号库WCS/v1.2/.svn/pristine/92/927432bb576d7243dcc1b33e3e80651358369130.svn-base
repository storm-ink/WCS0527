using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using Microsoft.VisualStudio.TestTools.UnitTesting;
using Wcs.DefaultImpls.Crane;
using Wcs.Framework.Cfg;
namespace UnitTestProject1
{
    [TestClass]
    public class 堆垛机测试
    {
        [TestMethod]
        public void LA解析测试()
        {
            var state=CraneStatus.BackToTheOrigin;
            int column=1,level=2;
            ForkHorizontalPosition forkHorizontalPosition=ForkHorizontalPosition.Left;
            ForkVerticalPosition forkVerticalPosition=ForkVerticalPosition.Middle;
            bool atStation=true;
            int erroCode = 999;
            CraneEvent evt=CraneEvent.EndPickup;
            string taskId=string.Format("{0:00000000}", 123);
            var telex = new StringBuilder()
                .Append((Char)2)
                .Append("LA")
                .AppendFormat("{0:00}", (int)state)
                .AppendFormat("{0:000}", column)
                .AppendFormat("{0:000}", level)
                .AppendFormat("{0}", (int)forkHorizontalPosition)
                .AppendFormat("{0}", (int)forkVerticalPosition)
                .AppendFormat("{0}",Convert.ToInt32(atStation))
                .AppendFormat("{0:0000}", erroCode)
                .AppendFormat("{0}", (int)evt)
                .Append(taskId)
                .Append((Char)3)
                .ToString();

            RequestStateCommandReplyTelexTransferObject la = new RequestStateCommandReplyTelexTransferObject(telex);

            Assert.AreEqual(la.State, state);
            Assert.AreEqual(la.Column, column);
            Assert.AreEqual(la.Level, level);
            Assert.AreEqual(la.ForkHorizontalPosition, forkHorizontalPosition);
            Assert.AreEqual(la.ForkVerticalPosition, forkVerticalPosition);
            Assert.AreEqual(la.AtStation, atStation);
            Assert.AreEqual(la.Event, evt);
            Assert.AreEqual(la.TaskId, taskId);
        }

