        [TestMethod]
        public void 生成x列y层的位置配置()
        {
            StringBuilder sb = new StringBuilder();
            int x = 100;
            int y = 12;
            int line = 1; //第几排
            ForkDirection fd=ForkDirection.Left;
            for (int i = 1; i <= x; i++)
            {
                for (int j = 1; j <= y; j++)
                {
                    sb.AppendLine(String.Format(@"<location userCode=""{3:00}-{0:000}-{1:000}"" column=""{0}"" level=""{0}"" forkDirection=""{2}"" />", i, j, fd,line));
                }
            }

            fd = ForkDirection.Right;
            for (int i = 1; i <= x; i++)
            {
                for (int j = 1; j <= y; j++)
                {
                    sb.AppendLine(String.Format(@"<location userCode=""{3:00}-{0:000}-{1:000}"" column=""{0}"" level=""{0}"" forkDirection=""{2}"" />", i, j, fd, line));
                }
            }

            Console.WriteLine(sb);
            System.Windows.Forms.Clipboard.SetText(sb.ToString());
        }
    }
}
