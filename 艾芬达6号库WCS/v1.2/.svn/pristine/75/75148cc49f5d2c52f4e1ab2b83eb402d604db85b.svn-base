<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Client" namespace="Client.Conveyor" auto-import="false">
  <class name="Occupy" table="`ConveyorOccupys`"  schema-action="none" batch-size="500">
