using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Net.Sockets;

namespace Gensong
{
    [Serializable]
    public class RequestTelexReceivedEventArgs : EventArgs
    {
        public RequestTelexReceivedEventArgs(RequestTelex telex)
        {
            this.Telex = telex;
        }

        /// <summary>
        /// 上位机的请求报文。
        /// </summary>
        public RequestTelex Telex { get; private set; }
    }
}
