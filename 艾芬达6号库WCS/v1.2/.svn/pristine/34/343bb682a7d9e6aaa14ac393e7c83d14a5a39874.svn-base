<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Client" namespace="Client.SingleForkCrane" auto-import="false">
  <class name="StatusDiagnosisData" table="`SingleForkCraneStatus`"  schema-action="none" batch-size="500">
    <id name="Id" column="`Id`" type="Int32">
      <generator class="increment">
      </generator>
    </id>
    <version name="Version" type="Int32" column="`Version`" unsaved-value="0" />
    <property name="LogId" type="Int32" column="`LogId`" not-null="true" />
    <property name="ProjectId" type="Int32" column="`ProjectId`" not-null="true" />
    <property name="CreatedAt" type="DateTime2" not-null="true">
      <column name="`CreatedAt`" sql-type="DateTime2" />
    </property>
    <property name="LongDate" type="DateTime2">
      <column name="`LongDate`" sql-type="DateTime2" />
    </property>
    <property name="Name" column="`Name`" type="String" not-null="true" />
    <property name="State" column="`State`" type="CraneStatus" />
    <property name="Column" column="`Column`" type="Int32" />
    <property name="Level" column="`Level`" type="Int32" />
    <property name="ForkHorizontalPosition" column="`ForkHorizontalPosition`" type="ForkHorizontalPosition" />
    <property name="ForkVerticalPosition" column="`ForkVerticalPosition`" type="ForkVerticalPosition" />
    <property name="AtStation" column="`AtStation`" type="Boolean" />
    <property name="ErrorCode" column="`ErrorCode`" type="Int32" />
    <property name="Event" column="`Event`" type="CraneEvent" />
    <property name="TaskId" column="`TaskId`" type="String" />
    <property name="Telex" column="`Telex`" type="String" />
    <!--<many-to-one name="Alarm" class="Alarm" column="`ErrorCode`" not-found="ignore" lazy="no-proxy" insert="false" />-->
  </class>
  <database-object>
    <create>
      <![CDATA[      
      CREATE TABLE [dbo].[SingleForkCraneStatus](
	      [Id] [int] NOT NULL PRIMARY KEY NONCLUSTERED,
        [LogId] [int] NOT NULL,
	      [ProjectId] [int] NOT NULL,
        [CreatedAt] [datetime2](7) NULL,
        [LongDate] [datetime2](7) NULL,
	      [Name] [nvarchar](255) NOT NULL,
	      [State] [int] NULL,
	      [Column] [int] NULL,
	      [Level] [int] NULL,
	      [ForkHorizontalPosition] [int] NULL,
	      [ForkVerticalPosition] [int] NULL,
	      [AtStation] [bit] NULL,
	      [ErrorCode] [int] NULL,
	      [Event] [int] NULL,
	      [TaskId] [nvarchar](255) NULL,
	      [Telex] [nvarchar](255) NULL,
        [Version] [int] NOT NULL
      ) ON [PRIMARY]
      ]]>
    </create>
    <drop>
      <![CDATA[
      IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[SingleForkCraneStatus]') AND type in (N'U'))
      DROP TABLE [dbo].[SingleForkCraneStatus]
      ]]>
    </drop>
  </database-object>
  <database-object>
    <create>
      <![CDATA[
            CREATE CLUSTERED INDEX [IX_SingleForkCraneStatus_LongDate] ON dbo.[SingleForkCraneStatus]
            (
            LongDate
            ) WITH( STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON) ON [PRIMARY]

        ]]>
    </create>
    <drop>

    </drop>
  </database-object>
