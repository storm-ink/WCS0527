<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://tempuri.org/" elementFormDefault="qualified" targetNamespace="http://tempuri.org/" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="BlankPallentIn">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="ioPort" nillable="true" type="xs:string" />
        <xs:element minOccurs="0" name="num" type="xs:int" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="BlankPallentInResponse">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="BlankPallentInResult" nillable="true" type="xs:string" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="BlankPallentOut">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="ioPort" nillable="true" type="xs:string" />
        <xs:element minOccurs="0" name="num" type="xs:int" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="BlankPallentOutResponse">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="BlankPallentOutResult" nillable="true" type="xs:string" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="ReApplayForPosition">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="taskId" nillable="true" type="xs:string" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="ReApplayForPositionResponse">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="ReApplayForPositionResult" nillable="true" type="xs:string" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="VerificationBarcode">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="barcode" nillable="true" type="xs:string" />
        <xs:element minOccurs="0" name="eventPort" nillable="true" type="xs:string" />
        <xs:element minOccurs="0" name="canClearImcompleteCheckoutTask" type="xs:boolean" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="VerificationBarcodeResponse">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" name="VerificationBarcodeResult" type="xs:boolean" />
        <xs:element minOccurs="0" name="msg" nillable="true" type="xs:string" />
        <xs:element minOccurs="0" name="isCheckInventory" type="xs:boolean" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>