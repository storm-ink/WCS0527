    /// <summary>
    /// 报警状态.
    /// </summary>
    [Description("报警状态")]
    [DataContract]
    public class AlarmNetTransferObject
    {
        [Description("货位号")]
        [DataMember]
        public UInt16 PosNo { get; set; }
        [Description("是否手动")]
        [DataMember]
        public Boolean Manual { get; set; }
        [Description("离线（隔离开关断开）")]
        [DataMember]
        public Boolean Isolator{get;set;}
        [Description("电路保护器断开（断路器断开）")]
        [DataMember]
        public Boolean Breaker { get; set; }
        [Description("光电异常")]
        [DataMember]
        public Boolean Photocell { get; set; }
        [Description("运行超时")]
        [DataMember]
        public Boolean RunOvertime { get; set; }
        [Description("占位超时")]
        [DataMember]
        public Boolean OccupyOvertime { get; set; }
        [Description("有任务无货")]
        [DataMember]
        public Boolean TaskNoGoods { get; set; }
        [Description("使用状态")]
        [DataMember]
        public Byte MotorUseStatus{get;set;}
        [Description("X轴电机变频器故障")]
        [DataMember]
        public Boolean X_MotorVAF { get; set; }
        [Description("Y轴电机变频器故障")]
        [DataMember]
        public Boolean Y_MotorVAF { get; set; }
        [Description("X轴电机正反转接触器故障")]
        [DataMember]
        public Boolean X_MotorContactor { get; set; }
        [Description("X轴电机抱闸接触器故障")]
        [DataMember]
        public Boolean X_MotorBraker { get; set; }
        [Description("Y轴电机正反转接触器故障")]
        [DataMember]
        public Boolean Y_MotorContactor { get; set; }
        [Description("Y轴电机抱闸接触器故障")]
        [DataMember]
        public Boolean Y_MotorBraker { get; set; }
        [Description("顶升电机正反转接触器故障")]
        [DataMember]
        public Boolean Lift_MotorContactor { get; set; }
        [Description("顶升电机抱闸接触器故障")]
        [DataMember]
        public Boolean Lift_MotorBraker { get; set; }
        [Description("预留")]
        [DataMember]
        public Byte Spare { get; set; }
