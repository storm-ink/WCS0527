@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Client.RailGuidedVehicle.RailGuidedVehicleDiagnosisData>
@{
    Layout = null;
}

<table class="log-entries" id="table" >
<tr>
    <th>Id</th>
    <th>时间</th>
    <th>设备名</th>
    <th>任务号</th>
    <th>当前位置</th>
    <th>站台</th>
    <th>在站点</th>
    <th>状态</th>
    <th>事件</th>
    <th>托盘号</th>
    <th>起始位置</th>
    <th>终点位置</th>
    <th>任务模式</th>
    <th>报警码</th>
    <th>报文</th>
  
</tr>

@foreach (var item in Model)
{
<tr class="">
    <td>@item.LogId</td>
    <td class="longDate">@item.LongDate.ToString("yyyy-MM-dd HH:mm:ss.fff")</td>
    <td>@item.Name</td>
    <td>@item.TaskId</td>
    <td>@item.Position</td>
    <td>@item.CurrentStation</td>  
    <td>@item.AtStation</td>
    <td>@item.State</td>
    <td>@item.Event</td>
    <td>@item.ContainerCode</td>
    <td>@item.FromStation</td>
    <td>@item.ToStation</td>
    <td>@item.TaskMode</td>
    <td>@item.ErrorCode
        @if (item.Alarm != null)
    {
        <text>(@item.Alarm.Name)</text>
    }
    </td>
    <td>@item.Telex</td>
</tr>    
}
</table>



@if (Model.Count() > 0)
{
    @Html.PagedListPager(this.Model, pageIndex => Url.Action("Index", new { pageIndex }), new PagedListRenderOptions { DisplayItemSliceAndTotal = true, ItemSliceAndTotalFormat = "共 {2} 个" })
}