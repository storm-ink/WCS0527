<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Client" namespace="Client.RailGuidedVehicle" auto-import="false">
  <class name="Alarm" table="RailGuidedVehicleAlarms">
    <id name="Code" column="`Code`" type="Int32" generator="assigned" />
    <property name="Name" column="`Name`" type="String" not-null="true" />
    <property name="Type" column="`Type`" type="String" />
  </class>
</hibernate-mapping>
