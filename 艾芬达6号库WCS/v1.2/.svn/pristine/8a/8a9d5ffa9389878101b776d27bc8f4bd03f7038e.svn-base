        public void ClearTask(string deviceName, int equipmentTaskId)
        {
            var conveyorDevice = Wcs.Framework.Cfg
                  .WcsConfiguration
                  .Instance
                  .DeviceCollection
                  .ParticularDeviceCollection
                  .SelectMany(x => x.DeviceElements)
                  .Where(x => x.Device is Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                  .Select(x => x.Device as Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                  .Single(x => x.Name.Equals(deviceName, StringComparison.CurrentCultureIgnoreCase));

            var tsk = conveyorDevice.Tasks.FirstOrDefault(x => x.AssignmentID == equipmentTaskId);
            if (tsk == null)
            {
                throw new InvalidOperationException(string.Format("在 {0} 中未找到设备任务", deviceName, equipmentTaskId));
            }

            using (NHUnitOfWork unitOfWork = new NHUnitOfWork(System.Data.IsolationLevel.ReadUncommitted))
            {
                if (unitOfWork.session.Query<Wcs.Framework.EquipmentAction>().Any
                    (x => x.EquipmentTaskId == equipmentTaskId
                    && x.Status != Framework.EquipmentActionStatus.Completed
                    && x.Status != Framework.EquipmentActionStatus.Cancelled
                    && x.Status != Framework.EquipmentActionStatus.Error
                    && x.Status != Framework.EquipmentActionStatus.Suspend))
                {
                    throw new InvalidOperationException(string.Format("{0} 属于联机任务，不能被人工清除。",equipmentTaskId));
                }
            }

            Wcs.DefaultImpls.Conveyor.ApplyClearTaskCommand cmd = new DefaultImpls.Conveyor.ApplyClearTaskCommand(
                tsk.AssignmentID, 
                tsk.RotingNo, 
                tsk.StartMotorNo, 
                tsk.DestinationNo,
                Convert.ToUInt16(tsk.AtPacketIndex),
                Convert.ToUInt32(Wcs.Framework.SerialNumberFactory.GenerateRandomValue(int.MinValue,int.MaxValue))
                );

            conveyorDevice.Write(cmd, (device, _cmd) =>
            {
                return conveyorDevice.Tasks[_cmd.Index - 1].AssignmentID != _cmd.AssignmentID;
            });
        }

        public void DeleteTask(string deviceName, int equipmentTaskId)
        {
            var conveyorDevice = Wcs.Framework.Cfg
                   .WcsConfiguration
                   .Instance
                   .DeviceCollection
                   .ParticularDeviceCollection
                   .SelectMany(x => x.DeviceElements)
                   .Where(x => x.Device is Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Select(x => x.Device as Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Single(x => x.Name.Equals(deviceName, StringComparison.CurrentCultureIgnoreCase));

            var tsk = conveyorDevice.Tasks.FirstOrDefault(x => x.AssignmentID == equipmentTaskId);
            if (tsk == null)
            {
                throw new InvalidOperationException(string.Format("在 {0} 中未找到设备任务", deviceName, equipmentTaskId));
            }

            using (NHUnitOfWork unitOfWork = new NHUnitOfWork(System.Data.IsolationLevel.ReadUncommitted))
            {
                if (unitOfWork.session.Query<Wcs.Framework.EquipmentAction>().Any
                    (x => x.EquipmentTaskId == equipmentTaskId
                    && x.Status != Framework.EquipmentActionStatus.Completed
                    && x.Status != Framework.EquipmentActionStatus.Cancelled
                    && x.Status != Framework.EquipmentActionStatus.Error
                    && x.Status != Framework.EquipmentActionStatus.Suspend))
                {
                    throw new InvalidOperationException(string.Format("{0} 属于联机任务，不能被人工删除。", equipmentTaskId));
                }
            }

            Wcs.DefaultImpls.Conveyor.ApplyDeleteTaskCommand cmd = new DefaultImpls.Conveyor.ApplyDeleteTaskCommand(
                tsk.AssignmentID,
                tsk.RotingNo,
                tsk.StartMotorNo,
                tsk.DestinationNo,
                Convert.ToUInt16(tsk.AtPacketIndex),
                Convert.ToUInt32(Wcs.Framework.SerialNumberFactory.GenerateRandomValue(int.MinValue, int.MaxValue))
                );

            conveyorDevice.Write(cmd, (device, _cmd) =>
            {
                return conveyorDevice.Tasks[_cmd.Index - 1].AssignmentID != _cmd.AssignmentID;
            });
        }

        public void DeleteLocationTask(string deviceName, int posNo, int equipmentTaskId)
        {
            var conveyorDevice = Wcs.Framework.Cfg
                   .WcsConfiguration
                   .Instance
                   .DeviceCollection
                   .ParticularDeviceCollection
                   .SelectMany(x => x.DeviceElements)
                   .Where(x => x.Device is Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Select(x => x.Device as Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Single(x => x.Name.Equals(deviceName, StringComparison.CurrentCultureIgnoreCase));

            var tsk = conveyorDevice.Tasks.FirstOrDefault(x => x.AssignmentID == equipmentTaskId);
            if (tsk != null)
            {
                throw new InvalidOperationException(string.Format("{0} 还存在于任务区，无法被人工删除。", deviceName, equipmentTaskId));
            }

            var locTsk = conveyorDevice.LocationCurrentTasks.FirstOrDefault(x => x.TaskNo == equipmentTaskId);

            Wcs.DefaultImpls.Conveyor.ClearLocationTaskCommand cmd = new DefaultImpls.Conveyor.ClearLocationTaskCommand(
                locTsk.PosNo,
                locTsk.TaskNo,
                locTsk.TUID,
                Convert.ToUInt16(locTsk.AtPacketIndex),
                Convert.ToUInt32(Wcs.Framework.SerialNumberFactory.GenerateRandomValue(int.MinValue, int.MaxValue))
                );

            conveyorDevice.Write(cmd, (device, _cmd) =>
            {
                return conveyorDevice.LocationCurrentTasks[_cmd.Index - 1].TaskNo != _cmd.TaskNo;
            });
        }

        public object Call(string name, object[] args)
        {
            return this.InternalCall<object>(name, args);
        }

        public string[] AllOperations()
        {
            return _registeredCalls.Select(x => x.Key.Name).ToArray();
        }
    }
}
