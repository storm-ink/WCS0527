using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using Wcs.Client.Interfaces.Conveyor;
using NHibernate.Linq;
namespace Wcs.Client.Services
{
    public class ConveyorService : Wcs.Client.Interfaces.AbstractClientService, Wcs.Client.Interfaces.Conveyor.IConveyorService
    {
        public Interfaces.Conveyor.AlarmNetTransferObject[] GetAlarms(string deviceName)
        {
            var conveyorDevice = Wcs.Framework.Cfg
                   .WcsConfiguration
                   .Instance
                   .DeviceCollection
                   .ParticularDeviceCollection
                   .SelectMany(x => x.DeviceElements)
                   .Where(x => x.Device is Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Select(x => x.Device as Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Single(x => x.Name.Equals(deviceName, StringComparison.CurrentCultureIgnoreCase));

            var alarms = conveyorDevice
                .MachineAlarms
                .Select(x => new AlarmNetTransferObject
                {
                    PosNo = x.PosNo,
                    Breaker = x.Breaker,
                    Isolator = x.Isolator,
                    Lift_MotorBraker = x.Lift_MotorBraker,
                    Lift_MotorContactor = x.Lift_MotorContactor,
                    Manual = x.Manual,
                    MotorUseStatus = x.MotorUseStatus,
                    OccupyOvertime = x.OccupyOvertime,
                    Photocell = x.Photocell,
                    RunOvertime = x.RunOvertime,
                    Spare = x.Spare,
                    TaskNoGoods = x.TaskNoGoods,
                    X_MotorBraker = x.X_MotorBraker,
                    X_MotorContactor = x.X_MotorContactor,
                    X_MotorVAF = x.X_MotorVAF,
                    Y_MotorBraker = x.Y_MotorBraker,
                    Y_MotorContactor = x.Y_MotorContactor,
                    Y_MotorVAF = x.Y_MotorVAF
                });

            return alarms.ToArray();
        }

        public Interfaces.Conveyor.HoldSignalNetTransferObject[] GetHoldSignals(string deviceName)
        {
            var conveyorDevice = Wcs.Framework.Cfg
                   .WcsConfiguration
                   .Instance
                   .DeviceCollection
                   .ParticularDeviceCollection
                   .SelectMany(x => x.DeviceElements)
                   .Where(x => x.Device is Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Select(x => x.Device as Wcs.DefaultImpls.Conveyor.ConveyorDevice)
                   .Single(x => x.Name.Equals(deviceName, StringComparison.CurrentCultureIgnoreCase));

            var occupiedSignals = conveyorDevice
                .OccupiedSignals
                .Select(x => new HoldSignalNetTransferObject
                {
                    AssignmentID = x.AssignmentID,
                    HandShake = (HoldSignalNetTransferObjectHandShake)x.HandShake,
                    IO_Data = x.IO_Data,
                    PosNo = x.PosNo,
                    TU_ID = x.TU_ID,
                    TU_Type = x.TU_Type
                });

            return occupiedSignals.ToArray();
        }

        public Interfaces.Conveyor.LocationNetTransferObject[] GetLocationStatus(string deviceName)
        {
            var conveyorDevice = Wcs.Framework.Cfg
