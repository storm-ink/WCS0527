using System;
using System.Collections.Generic;
using System.Linq;
using System.Windows.Forms;
using System.Collections;
using System.Net;

namespace ConveyorSimulationApplication
{
    static class Program
    {
        /// <summary>
        /// 应用程序的主入口点。
        /// </summary>
        [STAThread]
        static void Main(string[] args)
        {
            IPEndPoint ipEndPoint = null;
            if (args != null && args.Length > 0 && args[0].Split(':').Length == 2)
            {
                ipEndPoint = new IPEndPoint(IPAddress.Parse(args[0].Split(':')[0]), Convert.ToInt32(args[0].Split(':')[1]));
            }  
    
            Application.EnableVisualStyles();
            Application.SetCompatibleTextRenderingDefault(false);

            Application.Run(new Form1(ipEndPoint));
        }
    }
}
