        private void button1_Click(object sender, EventArgs e)
        {
            XmlDocument doc = new XmlDocument();
            doc.Load(Path.Combine(Application.StartupPath, "wcs.config.xml"));
            XmlNode db2DecoderElement = doc.SelectSingleNode("configuration/netPackageDecoders/netPackageDecoder[@name='netPackageDecoder1']");
            decoder = new DefaultConveyorNetPackageDecoder(db2DecoderElement);

            XmlNode db1DecoderElement = doc.SelectSingleNode("configuration/netPackageDecoders/netPackageDecoder[@name='netPackageDecoder2']");
            encoder = new DefaultConveyorNetPackageDecoder(db1DecoderElement);
        }

        Boolean 持续接收 = false;
        private void button2_Click(object sender, EventArgs e)
        {
