        private void button5_Click(object sender, EventArgs e)
        {
            try
            {
                if (!int.TryParse(textBox3.Text, out 数据包长度) || 数据包长度<=0)
                {
                    MessageBox.Show("数据包长度必须为数字，且必须大于 0");
                    textBox3.Focus();
                    return;
                }

                if (_thread == null)
                {
                    client = new TcpClient();
                    client.Connect(textBox1.Text, int.Parse(textBox2.Text));

                    _thread = new Thread(接收固定大小数据包时间统计);
                    _thread.Start();
                }
                else
                {
                    _thread.Abort();
                    _thread = null;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }

