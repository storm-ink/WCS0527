        UdpClient udpClient;
        Thread udpThread;
        private void button6_Click(object sender, EventArgs e)
        {
            if (udpClient!=null)
            {
                udpThread.Abort();
                Thread.Sleep(TimeSpan.FromMilliseconds(500d));
                udpClient.Close();
            }
            try
            {
                udpClient = new UdpClient();
                udpClient.Connect(new IPEndPoint(IPAddress.Parse(textBox1.Text),int.Parse(textBox2.Text)));
                udpThread = new Thread(new ThreadStart(udpReceived));
                udpThread.Start();

            }
            catch (Exception y)
            {
                MessageBox.Show(this, y.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        void udpReceived()
        {
            IPEndPoint remoteHost = null;
            while(udpClient!=null)
            {
                try
                {
                    byte[] buf = udpClient.Receive(ref remoteHost);
                    string bufs = Encoding.UTF8.GetString(buf);
                    addMsg("主机：{0}; 端口:{1}; 数据报长度:{2}", remoteHost.Address, remoteHost.Port, buf.Length);
                }
                catch (Exception ex)
                {
                    addMsg("发生错误:", ex);
                }

            }
        }

        private void Form1_FormClosing(object sender, FormClosingEventArgs e)
        {
            Process.GetCurrentProcess().Kill();
            Thread.CurrentThread.Abort();
        }

        class cssj
        {
            public Int32 no { get; set; }
            public long ms { get; set; }
            public Int32 size { get; set; }
        }
    }
