<?xml version="1.0"?>
<configuration>
  <system.diagnostics>
    <sources>
      <source name="conveyor" switchName="crn_switch" switchType="System.Diagnostics.SourceSwitch">
        <listeners>
          <clear/>
          <add name="console">
          </add>
        </listeners>
      </source>
    </sources>
    <switches>
      <add name="crn_switch" value="All"/>
    </switches>
    <sharedListeners>
      <add name="console" type="System.Diagnostics.ConsoleTraceListener" initializeData="false" traceOutputOptions="DateTime">
        <filter type="System.Diagnostics.EventTypeFilter" initializeData="Information"/>
      </add>
    </sharedListeners>
  </system.diagnostics>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0"/></startup></configuration>
