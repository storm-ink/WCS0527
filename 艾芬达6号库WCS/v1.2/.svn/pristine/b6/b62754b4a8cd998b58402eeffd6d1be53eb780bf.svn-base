<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Client" namespace="Client.Conveyor" auto-import="false">
  <class name="Task" table="`ConveyorTasks`"  schema-action="none" batch-size="500">
    <id name="Id" column="`Id`" type="Int32">
      <generator class="increment">
      </generator>
    </id>
    <version name="Version" type="Int32" column="`Version`" unsaved-value="0" />
    <property name="LogId" type="Int32" column="`LogId`" not-null="true" />
    <property name="ProjectId" type="Int32" column="`ProjectId`" not-null="true" />
    <property name="CreatedAt" type="DateTime2" not-null="true">
      <column name="`CreatedAt`" sql-type="DateTime2" />
    </property>
    <property name="LongDate" type="DateTime2">
      <column name="`LongDate`" sql-type="DateTime2" />
    </property>
    <property name="Name" column="`Name`" type="String" not-null="true" />

    <property name="HandShake" column="`HandShake`" type="TaskHandShake" />
    <property name="AssignmentID" column="`AssignmentID`" type="Int32" />
    <property name="TU_ID" column="`TU_ID`" type="Int32" />
    <property name="TU_Type" column="`TU_Type`" type="Int32" />
    <property name="IO_Data" column="`IO_Data`" type="Int32" />
    <property name="RotingNo" column="`RotingNo`" type="Int32" />
    <property name="StartMotorNo" column="`StartMotorNo`" type="Int32" />
    <property name="DestinationNo" column="`DestinationNo`" type="Int32" />
    <property name="Status" column="`Status`" type="TaskStatus" />
    <property name="ReadTask" column="`ReadTask`" type="Int32" />
    <property name="Spare" column="`Spare`" type="Int32" />
  </class>
  <database-object>
    <create>
      <![CDATA[      
      CREATE TABLE [dbo].[ConveyorTasks](
	      [Id] [int] NOT NULL PRIMARY KEY NONCLUSTERED,
        [LogId] [int] NOT NULL,
	      [ProjectId] [int] NOT NULL,
        [CreatedAt] [datetime2](7) NULL,
        [LongDate] [datetime2](7) NULL,
        [Version] [int] NOT NULL,
	      [Name] [nvarchar](255) NOT NULL,
        
	      [HandShake] [int] NULL,
	      [AssignmentID] [int] NULL,
	      [TU_ID] [int] NULL,
	      [TU_Type] [int] NULL,
	      [IO_Data] [int] NULL,
	      [RotingNo] [int] NULL,
	      [StartMotorNo] [int] NULL,
	      [DestinationNo] [int] NULL,
	      [Status] [int] NULL,
	      [ReadTask] [int] NULL,
	      [Spare] [int] NULL
      ) ON [PRIMARY]
      ]]>
    </create>
    <drop>
      <![CDATA[
      IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[ConveyorTasks]') AND type in (N'U'))
      DROP TABLE [dbo].[ConveyorTasks]
      ]]>
    </drop>
  </database-object>
  <database-object>
    <create>
      <![CDATA[
            CREATE CLUSTERED INDEX [IX_ConveyorTasks_LongDate] ON dbo.[ConveyorTasks]
            (
            LongDate
            ) WITH( STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON) ON [PRIMARY]

        ]]>
    </create>
    <drop>

    </drop>
  </database-object>
</hibernate-mapping>
