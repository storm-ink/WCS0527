
using System;
using System.Net;
using System.Windows.Forms;
using Gensong.ServiceCrane;
using System.ComponentModel;
using Gensong.MCS;
using System.Runtime.Serialization;

namespace Gensong
{
    class Globle
    {
        public static string HostName = Dns.GetHostName();
        public static CraneClient MCS = new CraneClient();
        public static ucCrane[] aUCrane;
        public static EProject eProject = EProject.DF;
        public static LA[] aLA;
        public static SShelf[] aShelf;
        public static bool TcpConnected;

        public static SShelf GetSShelf(string sCraneName)
        {
            if (aShelf == null) return null;
            foreach (var v in aShelf)
            {
                if (v == null) return null;
                if (v.CName == sCraneName) return v;
            }

            return null;
        }
        public static LA GetCraneLA(string sCraneName)
        {
            foreach (var v in aLA)
            {
                if (v != null && v.CName == sCraneName) return v;
            }

            return null;
        }

        /// <summary>获取锁</summary>
        public static bool OnLock(string sCraneName)
        {
            foreach (var v in aUCrane)
            {
                if (v.Crane.CName == sCraneName)
                {
                    //增加了是远程锁定用户是否是自己条件(v.Crane.LockUser == Globle.HostName) 2012/08/29 by aben
                    if (v.Crane.LockGuid != null && v.Crane.LockUser == Globle.HostName) return true;
                    v.Crane.LockGuid = MCS.OnLock(sCraneName, Globle.HostName);

                    return v.Crane.LockGuid != null;
                }
            }

            return false;
        }
        /// <summary>解除锁</summary>
        public static bool UnLock(string sCraneName)
        {
            foreach (var v in aUCrane)
            {
                if (v.Crane.CName == sCraneName)
                {
                    if (v.Crane.LockGuid == null) return true;
                    if (MCS.UnLock(sCraneName, v.Crane.LockGuid)) v.Crane.LockGuid = null;

                    return true;
                }
            }

            return false;
        }
        /// <summary>删除锁</summary>
        public static void DeLock()
        {
            foreach (var v in aUCrane)
            {
                if (v.Crane.LockGuid != null)
                {
                    MCS.DeLock(v.Crane.CName, "1235");
                }
            }
        }

        /// <summary>检查锁状态</summary>
        public static void CheckLock(Crane crn, Button btnLock)
        {
            try
            {
                if (!crn.Connected) { frmMsgbox.Show("无法连接堆垛机, 不能进行操作..."); return; }

                if (btnLock.Text.Trim() == "解锁")
                {
                    if (frmMsgbox.Show("确定要解除锁定吗?", Btn.YesNo) == DialogResult.No) return;

                    if (Globle.UnLock(crn.CName))
                        btnLock.Text = btnLock.Text.Length > 2 ? "  锁定" : "锁定";
                    else
                        Globle.CheckLock(crn, false);
                }
                else
                {
                    if (Globle.OnLock(crn.CName))
                        btnLock.Text = btnLock.Text.Length > 2 ? "  解锁" : "解锁";
                    else
                        Globle.CheckLock(crn, false);
                }
            }
            catch (Exception ex)
            {
                frmMsgbox.Show("操作失败: \r\n" + ex.ToString());
            }
        }
        /// <summary>检查锁</summary>
        public static bool CheckLock(Crane crn, bool bCheckLockNull)
        {
            if (crn.LA.LockGuid != null)
            {
                if (crn.LockGuid == null)
                {
                    frmMsgbox.Show("堆垛机已被其他终端锁定, 无法进行操作..."); return true;
                }
                else if (crn.LA.LockGuid != crn.LockGuid)
                {
                    crn.LockGuid = null;
                    frmMsgbox.Show("锁失效, 无法下发任务..."); return true;
                }
                else
                {
                    return false;
                }
            }
            else
            {
                if (crn.LockGuid != null)
                {
                    crn.LockGuid = null;
                    frmMsgbox.Show("锁失效, 无法下发任务..."); return true;
                }
                else if (bCheckLockNull)
                {
                    frmMsgbox.Show("未获取锁, 不能下发任务..."); return true;
                }
                else
                {
                    return false;
                }
            }
        }
        /// <summary>检查堆垛机状态, 判断是否可以下发任务; true:可以下发任务 false:不能下发任务</summary>
        public static bool CheckCraneOK(Crane crn)
        {
            if (crn == null) return false;

            if (!crn.Connected)
            {
                frmMsgbox.Show("无法连接设备, 不能下发任务..."); return false;
            }
            if (crn.LA == null)
            {
                frmMsgbox.Show("无法获取设备状态, 不能下发任务..."); return false;
            }

            return true;
        }
    }

    /// <summary>报警声音</summary>
    public class BeepInfo
    {
        static BeepInfo()
        {
            try
            {
                foreach (var sName in Task.rk.GetValueNames())
                {
                    if (sName == "BeepFrequency") Frequency = Convert.ToInt32(Task.rk.GetValue("BeepFrequency"));
                    else if (sName == "BeepPersist") Persist = Convert.ToInt32(Task.rk.GetValue("BeepPersist"));
                    else if (sName == "BeepInterval") Interval = Convert.ToInt32(Task.rk.GetValue("BeepInterval"));
                }
            }
            catch //(Exception ex)
            {
            }
        }

        /// <summary>频率</summary>
        public static int Frequency = 0x0230;
        /// <summary>频长</summary>
        public static int Persist = 180;
        /// <summary>间隔</summary>
        public static int Interval = 1200;

        /// <summary>保存配置到注册表</summary>
        public static void Save(int iF, int iP, int iI)
        {
            try
            {
                Frequency = iF; Persist = iP; Interval = iI;

                Task.rk.SetValue("BeepFrequency", iF);
                Task.rk.SetValue("BeepPersist", iP);
                Task.rk.SetValue("BeepInterval", iI);
            }
            catch //(Exception ex)
            {
            }
        }
    }

    /// <summary>枚举转换</summary>
    public class Util
    {
        /// <summary>字符转枚举</summary>
        public static T PEnum<T>(string s)
        {
            return (T)Enum.Parse(typeof(T), s);
        }

        /// <summary>获取枚举的描述</summary>
        public static string PDescription(Enum e)
        {
            try
            {
                var _internalCraneStatusTypeObj = Type.GetType("Gensong._internalCraneStatusType+" + e.GetType().Name);
                if (_internalCraneStatusTypeObj != null)
                {
                    return ((DescriptionAttribute)Attribute
                        .GetCustomAttribute(_internalCraneStatusTypeObj.GetMember(e.ToString())[0], typeof(DescriptionAttribute)))
                        .Description;
                }
                else
                {
                    return ((DescriptionAttribute)Attribute.GetCustomAttribute(e.GetType().GetMember(e.ToString())[0], typeof(DescriptionAttribute))).Description;
                }
             }
            catch //(Exception ex)
            {
                return e.ToString();
            }
        }
    }

