    [TestClass]
    public class 任务测试
    {
        [TestMethod]
        public void 创建任务输送线任务()
        {
            using (NHUnitOfWork unitOfWork = new NHUnitOfWork())
            {

                var startLocation = LocationConverter.ConvertibleCodeToLcation("1102@输送线1");
                var endLocation = LocationConverter.ConvertibleCodeToLcation("01002003@C001");

                Task task = new Task(Guid.NewGuid().ToString(),LocationConverter.ToLocationInfo(startLocation), LocationConverter.ToLocationInfo(endLocation));
              
                task.ContainerCodes.Add("托盘1");
                task.ContainerCodes.Add("托盘2");

                unitOfWork.session.Save(task);

                unitOfWork.Commit();
            }

        }


