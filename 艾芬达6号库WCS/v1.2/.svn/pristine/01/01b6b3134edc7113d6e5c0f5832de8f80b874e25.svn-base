<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <netPackageDecoders>
    <netPackageDecoder type="Wcs.Framework.DefaultConveyorNetPackageDecoder, ConveyorSimulationApplication" name="netPackageDecoder1">
      <collection type="Wcs.Framework.Devices.TaskBlock, ConveyorSimulationApplication" blockBytes="28" itemCount="100">
        <property name="HandShake" index="0" size="2" type="UInt16" />
        <property name="AssignmentID" index="2" size="4" type="UInt32" />
        <property name="TU_ID" index="6" size="2" type="UInt16" />
        <property name="TU_Type" index="8" size="2" type="UInt16" />
        <property name="IO_Data" index="10" size="2" type="UInt16" />
        <property name="RotingNo" index="12" size="2" type="UInt16" />
        <property name="StartMotorNo" index="14" size="2" type="UInt16" />
        <property name="DestinationNo" index="16" size="2" type="UInt16" />
        <property name="TaskStatus" index="18" size="2" type="UInt16" />
        <property name="ReadTask" index="20" size="4" type="UInt32" />
        <property name="spare" index="24" size="4" type="UInt32" />
      </collection>
      <collection type="Wcs.Framework.Devices.LocationCurrentTask, ConveyorSimulationApplication" blockBytes="10" itemCount="200">
        <property name="PosNo" index="0" size="2" type="UInt16" />
        <property name="TaskNo" index="2" size="4" type="UInt32" />
        <property name="TUID" index="6" size="2" type="UInt16" />
        <property name="Str_Rcv_X" index="8.0" size="1" type="Boolean" />
        <property name="Fnh_Rcv_X" index="8.1" size="1" type="Boolean" />
        <property name="Rqs_Snt" index="8.2" size="1" type="Boolean" />
        <property name="Rcv_Rdy" index="8.3" size="1" type="Boolean" />
        <property name="Str_Rcv_Y" index="8.4" size="1" type="Boolean" />
        <property name="Fnh_Rcv_Y" index="8.5" size="1" type="Boolean" />
      </collection>
      <collection type="Wcs.Framework.Devices.ConveyorLocationState, ConveyorSimulationApplication" blockBytes="4" itemCount="200">
        <property name="PosNo" index="0" size="2" type="UInt16" />
        <property name="Status" index="2" size="2" type="UInt16" />
      </collection>
      <collection type="Wcs.Framework.Devices.MachineAlarms, ConveyorSimulationApplication" blockBytes="6" itemCount="200">
        <property name="PosNo" index="0" size="2" type="UInt16" />
        <property name="Manual" index="2" size="1" type="Boolean" />
        <property name="Isolator" index="2.1" size="1" type="Boolean" />
        <property name="Breaker" index="2.2" size="1" type="Boolean" />
        <property name="Photocell" index="2.3" size="1" type="Boolean" />
        <property name="RunOvertime" index="2.4" size="1" type="Boolean" />
        <property name="OccupyOvertime" index="2.5" size="1" type="Boolean" />
        <property name="TaskNoGoods" index="2.6" size="1" type="Boolean" />
        <property name="MotorUseStatus" index="3" size="1" type="Byte" />
        <property name="X_MotorVAF" index="4" size="1" type="Boolean" />
        <property name="Y_MotorVAF" index="4.1" size="1" type="Boolean" />
        <property name="X_MotorContactor" index="4.2" size="1" type="Boolean" />
        <property name="X_MotorBraker" index="4.3" size="1" type="Boolean" />
        <property name="Y_MotorContactor" index="4.4" size="1" type="Boolean" />
        <property name="Y_MotorBraker" index="4.5" size="1" type="Boolean" />
        <property name="Lift_MotorContactor" index="4.6" size="1" type="Boolean" />
        <property name="Lift_MotorBraker" index="4.7" size="1" type="Boolean" />
        <property name="Spare" index="5" size="1" type="Byte" />
      </collection>
      <collection type="Wcs.Framework.Devices.OccupyStatus, ConveyorSimulationApplication" blockBytes="4" itemCount="200">
        <property name="PosNo" index="0" size="2" type="UInt16" />
        <property name="PhocllUseStatus" index="2" size="1" type="Byte" />
        <property name="FroProPotocell" index="3" size="1" type="Boolean" />
        <property name="FroPosPotocell" index="3.1" size="1" type="Boolean" />
        <property name="FroSloPotocell" index="3.2" size="1" type="Boolean" />
        <property name="AftProPotocell" index="3.3" size="1" type="Boolean" />
        <property name="AftPosPotocell" index="3.4" size="1" type="Boolean" />
        <property name="AftSloPotocell" index="3.5" size="1" type="Boolean" />
        <property name="UpPotocell" index="3.6" size="1" type="Boolean" />
        <property name="DownPotocell" index="3.7" size="1" type="Boolean" />
      </collection>
      <collection type="Wcs.Framework.Devices.OccupiedSignal, ConveyorSimulationApplication" blockBytes="14" itemCount="50">
        <property name="PosNo" index="0" size="2" type="UInt16" />
        <property name="HandShake" index="2" size="2" type="UInt16" />
        <property name="AssignmentID" index="4" size="4" type="UInt32" />
        <property name="TU_ID" index="8" size="2" type="UInt16" />
        <property name="TU_Type" index="10" size="2" type="UInt16" />
        <property name="IO_Data" index="12" size="2" type="UInt16" />
      </collection>
      <collection type="Wcs.Framework.Devices.CraneWorkModeKeyInfo, ConveyorSimulationApplication" blockBytes="4" itemCount="8">
        <property name="CraneNo" index="0" size="2" type="UInt16" />
        <property name="IsManual" index="2.0" size="1" type="Boolean" />
        <property name="IsBrake" index="2.1" size="1" type="Boolean" />
      </collection>
    </netPackageDecoder>
    <netPackageDecoder type="Wcs.Framework.DefaultConveyorNetPackageDecoder, ConveyorSimulationApplication" name="netPackageDecoder2">
      <collection type="Wcs.Framework.Devices.SendTaskBlock, ConveyorSimulationApplication" blockBytes="24" itemCount="1">
        <property name="HandShake" index="0" size="2" type="UInt16" />
        <property name="AssignmentID" index="2" size="4" type="UInt32" />
        <property name="TU_ID" index="6" size="2" type="UInt16" />
        <property name="TU_Type" index="8" size="2" type="UInt16" />
        <property name="IO_Data" index="10" size="2" type="UInt16" />
        <property name="RotingNo" index="12" size="2" type="UInt16" />
        <property name="StartMotorNo" index="14" size="2" type="UInt16" />
        <property name="DestinationNo" index="16" size="2" type="UInt16" />
        <property name="Index" index="18" size="2" type="UInt16" />
        <property name="Spare" index="20" size="4" type="UInt32" />
      </collection>
      <collection type="Wcs.Framework.Devices.SendOccupiedSignal, ConveyorSimulationApplication" blockBytes="16" itemCount="1">
        <property name="PosNo" index="0" size="2" type="UInt16" />
        <property name="HandShake" index="2" size="2" type="UInt16" />
        <property name="AssignmentID" index="4" size="4" type="UInt32" />
        <property name="TU_ID" index="8" size="2" type="UInt16" />
        <property name="TU_Type" index="10" size="2" type="UInt16" />
        <property name="IO_Data" index="12" size="2" type="UInt16" />
        <property name="Index" index="14" size="2" type="UInt16" />
      </collection>
      <collection type="Wcs.Framework.Devices.SendClearLocationCurrentTask, ConveyorSimulationApplication" blockBytes="10" itemCount="1">
        <property name="PosNo" index="0" size="2" type="UInt16" />
        <property name="TaskNo" index="2" size="4" type="UInt32" />
        <property name="TUID" index="6" size="2" type="UInt16" />
        <property name="Index" index="8" size="2" type="UInt16" />
      </collection>
      <!--<collection type="Wcs.Framework.Devices.SendRgvTaskBlock, ConveyorSimulationApplication" blockBytes="34" itemCount="6">
        <property name="SC_No" index="0" size="2" type="UInt16" />
        <property name="Chain1_TaskNo" index="2" size="4" type="UInt32" />
        <property name="FromStation1" index="6" size="2" type="UInt16" />
        <property name="ToStation1" index="8" size="2" type="UInt16" />
        <property name="Chain1_FirstAction" index="10" size="2" type="UInt16" />
        <property name="Chain1_SecondAction" index="12" size="2" type="UInt16" />
        <property name="Chain2_TaskNo" index="14" size="4" type="UInt32" />
        <property name="FromStation2" index="18" size="2" type="UInt16" />
        <property name="ToStation2" index="20" size="2" type="UInt16" />
        <property name="Chain2_FirstAction" index="22" size="2" type="UInt16" />
        <property name="Chain2_SecondAction" index="24" size="2" type="UInt16" />
        <property name="Command" index="26" size="2" type="UInt16" />
        <property name="ClearTaskCommand" index="28" size="2" type="UInt16" />
        <property name="Received" index="30" size="4" type="UInt32" />
      </collection>-->
    </netPackageDecoder>
  </netPackageDecoders>
  <!--
  物理设备集合
    堆垛机
      name:设备名
      no:编号
      ip:主机地址
      port:tcp端口
    输送线
      name:设备名
      no:编号
      ip:主机地址
      port:tcp端口
    穿梭车
      name:设备名
      no:编号
      ip:主机地址
      port:tcp端口  
  -->
  <devices>
    <cranes>
      <crane name="c001" no="1" ip="192.168.1.11" port="4001" receiveTimeout="2000" connectTimeout="2000" sendTimeout="3000"/>
      <crane name="c002" no="2" ip="192.168.1.12" port="4001" receiveTimeout="2000" connectTimeout="2000" sendTimeout="3000"/>
