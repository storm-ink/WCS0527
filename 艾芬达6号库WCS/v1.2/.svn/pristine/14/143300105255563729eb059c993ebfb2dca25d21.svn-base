        private void btnRandom_Click(object sender, EventArgs e)
        {
            if (Test.Get(crn.CName).eTaskType == ETaskType.Null || Test.Get(crn.CName).eTaskType == ETaskType.Finish)
            {
                if (!crn.Connected) { frmMsgbox.Show("无法连接堆垛机, 不能进行操作..."); return; }
                if (Globle.CheckLock(crn, true)) return;
                if (Globle.CheckCraneOK(crn) == false) return;

                Test.Get(crn.CName).eTaskType = ETaskType.Random; lblItem.Text = "随机";
                Test.Get(crn.CName).TestStart(btnLine.Text, btnCol.Text, btnRow.Text);
            }
            else
            {
                frmMsgbox.Show("有测试任务, 终止后才能运行");
            }
        }
        private void btnStop_Click(object sender, EventArgs e)
        {
            Test.Get(crn.CName).TestStop(); Test.Get(crn.CName).eTaskType = ETaskType.Null; lblItem.Text = "终止";
        }

        private bool CheckOK
        {
            get
            {
                if (crn == null) return false;

                if (!crn.Enabled)
                {
                    frmMsgbox.Show("设备不可用, 无法下发任务..."); return false;
                }
                if (!crn.Connected)
                {
                    frmMsgbox.Show("设备通信中断, 无法下发任务..."); return false;
                }
                if (crn.LA == null)
                {
                    frmMsgbox.Show("无法获取设备状态, 不能下发任务..."); return false;
                }

                return true;
            }
        }

    }
