using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;

namespace Client
{
    /// <summary>
    /// 指示在导出时应该忽略
    /// </summary>
    public class IgnoreExportAttribute:Attribute
    {
        public IgnoreExportAttribute()
        {
            Ignore = true;
        }
        /// <summary>
        /// 忽略
        /// </summary>
        public Boolean Ignore { get; set; }
    }
}
