using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Diagnostics;
using System.Threading;
using System.Windows.Forms;

namespace Gensong
{
    public partial class Crane
    {
        /// <summary>
        /// 表示放货动作。
        /// </summary>
        private class UnloadCraneAction : CraneAction
        {
            Queue<Action> _steps = new Queue<Action>();

            /// <summary>
            /// 
            /// </summary>
            /// <param name="crane"></param>
            /// <param name="direction">向哪个方向放货。</param>
            public UnloadCraneAction(Crane crane, EForkLR direction, Boolean isChildActin)
                : base(crane, isChildActin)
            {
                Direction = direction;

                this.Starting += new EventHandler(UnloadCraneAction_Starting);
                this.Completed += new EventHandler(UnloadCraneAction_Completed);

                switch (direction)
                {
                    case EForkLR.L:
                        {
                            Action step1 = () => { crane.Fork.VPosition = ECraneTL.E1; };
                            Action step2 = () => { crane.Fork.HPosition = ECraneLR.E2; };
                            Action step3 = () => { crane.Fork.HPosition = ECraneLR.E3; };
                            Action step4 = () => { crane.Fork.VPosition = ECraneTL.E0; };
                            Action step5 = () => { crane.Fork.VPosition = ECraneTL.E2; };
                            Action step6 = () => { crane.Fork.HPosition = ECraneLR.E2; };
                            Action step7 = () => { crane.Fork.HPosition = ECraneLR.E1; };


                            _steps.Enqueue(step1);
                            _steps.Enqueue(step2);
                            _steps.Enqueue(step3);
                            _steps.Enqueue(step4);
                            _steps.Enqueue(step5);
                            _steps.Enqueue(step6);
                            _steps.Enqueue(step7);

                        }
                        break;
                    case EForkLR.R:
                        {
                            Action step1 = () => { crane.Fork.VPosition = ECraneTL.E1; };
                            Action step2 = () => { crane.Fork.HPosition = ECraneLR.E4; };
                            Action step3 = () => { crane.Fork.HPosition = ECraneLR.E5; };
                            Action step4 = () => { crane.Fork.VPosition = ECraneTL.E0; };
                            Action step5 = () => { crane.Fork.VPosition = ECraneTL.E2; };
                            Action step6 = () => { crane.Fork.HPosition = ECraneLR.E4; };
                            Action step7 = () => { crane.Fork.HPosition = ECraneLR.E1; };

                            _steps.Enqueue(step1);
                            _steps.Enqueue(step2);
                            _steps.Enqueue(step3);
                            _steps.Enqueue(step4);
                            _steps.Enqueue(step5);
                            _steps.Enqueue(step6);
                            _steps.Enqueue(step7);
                        }

                        break;
                    default:
                        break;
                }
            }

            void UnloadCraneAction_Completed(object sender, EventArgs e)
            {
                this.Crane.IsLoaded = false;
                this.Crane.LastEvent = ECraneEvent.E05;
                if (this.IsChildAction == false)
                {
                    this.Crane.LastEvent = ECraneEvent.E06;
                    this.Crane.StateInternal = CraneStateInternal.Waiting;
                }
            }

            void UnloadCraneAction_Starting(object sender, EventArgs e)
            {
                this.Crane.LastEvent = ECraneEvent.E04;
                this.Crane.StateInternal = CraneStateInternal.Unloading;
            }
            public EForkLR Direction { get; private set; }

            public override void ExecuteStep()
            {
                Logger.Debug("UnloadCraneAction.ExecuteStep");

                if (_steps.Count == 0)
                {
                    throw new InvalidOperationException("放货动作已在上一步完成。");
                }


                if (IsStarted == false)
                {
                    OnStarting(EventArgs.Empty);
                    IsStarted = true;
                }

                Action step = _steps.Dequeue();
                step();
                if (_steps.Count == 0)
                {
                    OnCompleted(EventArgs.Empty);
                }
            }
        }

    }
}