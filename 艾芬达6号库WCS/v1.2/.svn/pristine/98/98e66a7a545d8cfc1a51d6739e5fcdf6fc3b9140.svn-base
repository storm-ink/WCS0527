        private void _craneProxy_ResponseTelexReceived(object sender, ResponseEvent e)
        {
            if (e.Telex is LA)
            {
                LA la = (LA)e.Telex;
                Action m = () =>
                {
                    var taskItem = bindingSource1.List.Cast<TaskItem>().SingleOrDefault(x => x.TaskNo == la.TaskId);
                    if (taskItem != null)
                    {
                        switch (la.Event)
                        {
                            case ECraneEvent.E01: taskItem.ExecuteState = ETaskExecuteState.Running; break;
                            case ECraneEvent.E02: taskItem.ExecuteState = ETaskExecuteState.Geting; break;
                            case ECraneEvent.E03: taskItem.ExecuteState = ETaskExecuteState.Getend; break;
                            case ECraneEvent.E04: taskItem.ExecuteState = ETaskExecuteState.Seting; break;
                            case ECraneEvent.E05: taskItem.ExecuteState = ETaskExecuteState.Setend; break;
                            case ECraneEvent.E06: taskItem.ExecuteState = ETaskExecuteState.Finished; break;
                            case ECraneEvent.E07: taskItem.ExecuteState = ETaskExecuteState.Stoped; break;
                            case ECraneEvent.E08: taskItem.ExecuteState = ETaskExecuteState.FinishedError; break;
                            default: break;
                        }

                        //dgvTask.Refresh();
                    }
                };
                this.Invoke(m);
            }
        }

        public class TaskItem
        {
            public TaskItem()
            {
                this.AddTime = DateTime.Now;
                this.ExecuteState = ETaskExecuteState.Nosend;
            }
            public String TaskNo { get; set; }
            public EForkLR LoadDirection { get; set; }
            public Position LoadFrom { get; set; }
            public String LoadPosition
            {
                get
                {
                    return String.Format("{0}, {1}, {2}"
                        , LoadDirection
                        , LoadFrom.MCol
                        , LoadFrom.MRow
                        );
                }
            }
            public EForkLR UnloadDirection { get; set; }
            public Position UnloadTo { get; set; }
            public String UnloadPosition
            {
                get
                {
                    return String.Format("{0}, {1}, {2}"
                        , UnloadDirection
                        , UnloadTo.MCol
                        , UnloadTo.MRow
                        );
                }
            }

            public ETaskExecuteState ExecuteState { get; set; }
            public DateTime AddTime { get; set; }
        }

        /// <summary>任务执行状态</summary>
        public enum ETaskExecuteState
        {
            /// <summary>未下发</summary>
            Nosend,
            /// <summary>正在运行</summary>
            Running,

            /// <summary>正在取货</summary>
            Geting,
            /// <summary>取货完成</summary>
            Getend,
            /// <summary>正在放货</summary>
            Seting,
            /// <summary>放货完成</summary>
            Setend,

            /// <summary>急停</summary>
            Stoped,

            /// <summary>正常完成</summary>
            Finished,
            /// <summary>错误完成</summary>
            FinishedError
        }



        /// <summary>堆垛机 通讯</summary>
        private Crane crn;
        public Crane Crane
        {
            set
            {
                if (crn != null)
                    crn.EResponseTelex -= new EventHandler<ResponseEvent>(_craneProxy_ResponseTelexReceived);

                crn = value;

                //bindingSource1.Clear();

                //if (crn != null)
                //    crn.EResponseTelex += new EventHandler<ResponseEvent>(_craneProxy_ResponseTelexReceived);
            }
        }

