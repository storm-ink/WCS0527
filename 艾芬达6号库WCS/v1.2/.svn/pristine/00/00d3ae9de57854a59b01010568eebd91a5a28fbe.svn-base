<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:tns="http://schemas.datacontract.org/2004/07/WCS" elementFormDefault="qualified" targetNamespace="http://schemas.datacontract.org/2004/07/WCS" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:complexType name="ArrayOfPathStatus">
    <xs:sequence>
      <xs:element minOccurs="0" maxOccurs="unbounded" name="PathStatus" nillable="true" type="tns:PathStatus" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="ArrayOfPathStatus" nillable="true" type="tns:ArrayOfPathStatus" />
  <xs:complexType name="PathStatus">
    <xs:sequence>
      <xs:element minOccurs="0" name="EndLocatin" nillable="true" type="xs:string" />
      <xs:element minOccurs="0" name="Rate" type="xs:decimal" />
      <xs:element minOccurs="0" name="StartLocation" nillable="true" type="xs:string" />
    </xs:sequence>
  </xs:complexType>
  <xs:element name="PathStatus" nillable="true" type="tns:PathStatus" />
</xs:schema>