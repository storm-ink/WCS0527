        #endregion

        public override Element Clone()
        {
            throw new NotImplementedException();
        }

        public Warning[] GetWarings()
        {
            if (_alarmsCache == null || _alarmsCache.Length == 0)
            {
                return new Warning[0];
            }

            List<Warning> result = new List<Warning>();
            foreach (var item in _alarmsCache)
            {
                var alarm = item.ToAlarms();
                if (alarm == null || alarm.Length == 0)
                {
                    continue;
                }

                Warning w = new Warning();
                w.DeviceType = "输送线";
                w.DeviceName = string.Format("{0} 号货位", item.PosNo);
                w.Message = string.Join(",", alarm);

                result.Add(w);
            }

            return result.ToArray();
        }

        public override float WidthScale
        {
            get
            {
                return 1f;
            }
        }

        public override float HeightScale
        {
            get
