@using (Ajax.BeginForm("Index_List", null, new AjaxOptions { UpdateTargetId = "list", LoadingElementId = "loading_img", OnBegin = "onListLoadBegin", OnFailure = "onListLoadFailure", OnSuccess = "onListLoadSuccess", OnComplete = "onListLoadComplete" }, new { id = "spec_form", target = "_blank" }))
 {
<label>设备名：<input name="NameToMatch" style="width:100px" /></label>
<label>任务号：<input name="AssignmentID" style="width:50px"/></label>
<label>路径号：<input name="RotingNo" style="width:50px"/></label>
<label>起点：<input name="StartMotorNo" style="width:50px"/></label>
<label>终点：<input name="DestinationNo" style="width:50px"/></label>
<label>握手：@Html.DropDownList("HandShake",EnumHelper.ToSelectList<Client.Conveyor.TaskHandShake>(null),"",null)</label>
<label>状态：@Html.DropDownList("Status",EnumHelper.ToSelectList<Client.Conveyor.TaskStatus>(null),"",null)</label>
<label>时间从 <input name="DateMin" style="width:100px;" id="DateMin" value="@DateTime.Now.ToString("yyyy-MM-dd")" /></label>
<label>到</label>
<label><input name="DateMax" style="width:100px;" id="DateMax" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" /></label>
<label>每页
<select name="pageSize">
    <option value="5">5</option>
    <option value="10">10</option>
    <option value="15" selected="selected">15</option>
    <option value="20">20</option>
    <option value="50">50</option>
    <option value="100">100</option>
</select> 
</label> 
 <label>排序:<select name="Array" id="Array">
     <option value="升序">升序</option>
     <option value="降序" selected="selected">降序</option>
          </select></label>

<input type="hidden" name="mode" value="@Request["mode"]" />
<input type="submit" value="查询" />

<input type="reset" value="重置" />
<input type="hidden" id="pageIndex" name="pageIndex" value="1" />
   <img style="display:none;width:16px" id="loading_img" src="@Url.Content("~/Content/loading.gif")" alt="loading" />
 }
 </div>
<div id="list">
</div>