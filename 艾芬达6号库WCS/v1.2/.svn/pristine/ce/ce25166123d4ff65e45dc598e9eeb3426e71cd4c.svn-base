using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;

namespace Wcs.Client.App.Elements
{
    /// <summary>
    /// 表示继承此接口的类是一个容器
    /// </summary>
    public interface IElementContainer
    {
        /// <summary>
        /// 是否可见
        /// </summary>
        Boolean Visible { get; set; }
        /// <summary>
        /// 指示是否包含指定的元素
        /// </summary>
        /// <param name="element"></param>
        /// <returns></returns>
        Boolean Contains(Element element);
    }
}
