using System;
using System.Diagnostics;
using System.Net;
using System.Net.Sockets;
using System.Text;
using System.Threading;

namespace 输送线模拟程序.TcpServer
{
    /// <summary>
    /// 实现一个简单的 Tcp 服务器。
    /// </summary>
    public class SimpleTcpServer
    {
        public event EventHandler<StartingEventArgs> Starting;
        public event EventHandler<StartedEventArgs> Started;
        public event EventHandler<StopingEventArgs> Stopping;
        public event EventHandler Stopped;
        public event EventHandler<ErrorEventArgs> Error;
        public event EventHandler<ClientAcceptedEventArgs> ClientAccepted;

        IPEndPoint _endPoint;
        TcpListener _tcpListener;
        Boolean _stopCalled;

        public SimpleTcpServer(String ip, Int32 port) : this(new IPEndPoint(System.Net.IPAddress.Parse(ip), port))
        {
        }
        public SimpleTcpServer(IPEndPoint endPoint)
        {
            _endPoint = endPoint;


            this.ClientAccepted += (sender, e) =>
            {
                //Logger.Info("TcpServer: 客户端连入 {0}。", e.TcpClient.Client.RemoteEndPoint);
            };

            this.Error += (sender, e) =>
            {
                //Logger.Error("TcpServer: 发生错误。");
            };
            this.Started += (sender, e) =>
            {
                //Logger.Info("TcpServer: 已启动。");
            };
            this.Starting += (sender, e) =>
            {
                //Logger.Info("TcpServer: 正在启动，侦听地址：{0}。", this.IPAddress);
            };
            this.Stopped += (sender, e) =>
            {
                //Logger.Info("TcpServer: 已停止。");
            };
            this.Stopping += (sender, e) =>
            {
                //Logger.Info("TcpServer: 正在停止。");
            };

        }

        public IPEndPoint IPAddress
        {
            get
            {
                return _endPoint;
            }
        }

        public void Start()
        {
            _stopCalled = false;
            Thread t = new Thread(new ThreadStart(Listen));
            t.Start();
        }

        public void Listen()
        {
            _tcpListener = new TcpListener(_endPoint);

            try
            {
                OnStarting(new StartingEventArgs(this.IPAddress));
                _tcpListener.Start();
                OnStarted(new StartedEventArgs(this.IPAddress));

                // 侦听循环
                while (!_stopCalled)
                {
                    if (!_tcpListener.Pending())
                    {
                        Thread.Sleep(1);
                        continue;
                    }
                    TcpClient tcpClient = _tcpListener.AcceptTcpClient();
                    tcpClient.ReceiveBufferSize = 0;

                    // 在新线程中引发事件
                    ClientAcceptedEventArgs e = new ClientAcceptedEventArgs(tcpClient);
                    ParameterizedThreadStart ts = new ParameterizedThreadStart(OnClientAccepted);
                    Thread t = new Thread(ts);
                    t.Start(new ClientAcceptedEventArgs(tcpClient));
                }
            }
            catch (Exception ex)
            {
                OnError(new ErrorEventArgs(ex));
            }
            finally
            {
                OnStopping(new StopingEventArgs(this.IPAddress));

                _tcpListener.Stop();

                OnStopped(new StopedEventArgs(this.IPAddress));
            }
        }
        public void Stop()
        {
            _stopCalled = true;
        }


        protected virtual void OnStarting(StartingEventArgs e)
        {
            if (this.Starting != null)
            {
                this.Starting(this, e);
            }
        }
        protected virtual void OnStarted(StartedEventArgs e)
        {
            if (this.Started != null)
            {
                this.Started(this, e);
            }
        }

        protected virtual void OnStopping(StopingEventArgs e)
        {
            if (this.Stopping != null)
            {
                this.Stopping(this, e);
            }
        }
        protected virtual void OnStopped(StopedEventArgs e)
        {
            if (this.Stopped != null)
            {
                this.Stopped(this, e);
            }
        }

        protected virtual void OnError(ErrorEventArgs e)
        {
            if (this.Error != null)
            {
                this.Error(this, e);
            }
        }
        protected virtual void OnClientAccepted(ClientAcceptedEventArgs e)
        {
            if (this.ClientAccepted != null)
            {
                this.ClientAccepted(this, e);
            }
        }

        private void OnClientAccepted(Object e)
        {
            OnClientAccepted((ClientAcceptedEventArgs)e);
        }
    }
}
