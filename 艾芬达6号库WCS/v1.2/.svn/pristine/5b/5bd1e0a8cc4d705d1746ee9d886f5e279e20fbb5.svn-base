using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Linq;
using System.Runtime.Serialization;
using System.Text;

namespace Wcs.Client.Interfaces.SinglePlantformRailGuidedVehicle
{

    /// <summary>
    /// 任务模式
    /// </summary>
    [DataContract]
    public enum SinglePlantformRailGuidedVehicleMode
    {
        /// <summary>无任务类型</summary>
        [Description("无任务类型")]
        [EnumMember]
        Initialized = 0,

        /// <summary>表示HB任务
        /// 全自动任务
        /// </summary>
        [Description("全自动任务")]
        [EnumMember]
        [Obsolete("穿梭车已改为上位机拆分任务，该任务类型已取消。")]
        AutomaticTask = 1,

        /// <summary>取货任务</summary>
        [Description("取货任务")]
        [EnumMember]
        Picking = 2,

        /// <summary>放货任务</summary>
        [Description("放货任务")]
        [EnumMember]
        Putting = 3,


        /// <summary>有货行走</summary>
        [Description("有货行走")]
        [EnumMember]
        WalkWithGoods = 4,

        /// <summary>无货行走</summary>
        [Description("无货行走")]
        [EnumMember]
        Walk = 5,

    }
}
