html {
    margin: 0;
    padding: 0;
}

body {
    background-color: #fff;
    font-size: 12px;
    font-family: 宋体;
    margin: 20px;
    padding: 0;
}

table {
    border-collapse: collapse;
    margin-top: 0.75em;
    border: 1px solid #e4e4e4;
}
th, td
{
    border: 1px solid #e4e4e4;
    white-space:nowrap;
    padding:4px;
}

.trace td
{
    color:Gray;
    font-style:italic;
}

.debug td
{
    color:Gray;
}

.info td
{
}

.warn td
{
    color:Orange;
    text-decoration:underline;
}

.error td
{
    color:Red;
}

.fatal td
{
    background-color: Red;
    color:White;
}


#loading_img
{
    width: 16px;
}