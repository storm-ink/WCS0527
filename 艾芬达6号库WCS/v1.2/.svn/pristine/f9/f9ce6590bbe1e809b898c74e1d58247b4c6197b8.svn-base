using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.ComponentModel;
using System.Runtime.Serialization;

namespace Wcs.Client.Interfaces.Conveyor
{
    /// <summary>
    /// 输送线光电状态，该对象包含有物理光电设备的实时工作状态信息
    /// </summary>
    [System.ComponentModel.Description("光电状态")]
    [DataContract]
    public class OccupyNetTransferObject
    {
        /// <summary>
        /// 获取或设置占位信号对应的货位号（信号源）
        /// </summary>
        /// <value>
        /// 货位对应的设备编码形式.即输送线位置对象 DeviceCode 值.
        /// </value>
        [Description("货位号")]
        [DataMember]
        public UInt16 PosNo { get; set; }
        /// <summary>
        /// 光电的使用状态，即此组使用了哪些光电
        /// </summary>
        [System.ComponentModel.Description("光电的使用状态")]
        [DataMember]
        public Byte PhocllUseStatus{get;set;}
        /// <summary>
        /// 指示前保护光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("前保护光电")]
        [DataMember]
        public Boolean FroProPotocell{get;set;}
        /// <summary>
        /// 指示前到位光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("前到位")]
        [DataMember]
        public Boolean FroPosPotocell{get;set;}
        /// <summary>
        /// 指示前减速光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("前减速")]
        [DataMember]       
        public Boolean FroSloPotocell{get;set;}
        /// <summary>
        /// 指示后保护光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("后保护")]
        [DataMember]
        public Boolean AftProPotocell { get; set; }
        /// <summary>
        /// 指示后到位光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("后到位")]
        [DataMember]
        public Boolean AftPosPotocell{get;set;}
        /// <summary>
        /// 指示后减速光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("后减速")]
        [DataMember]
        public Boolean AftSloPotocell{get;set;}
        /// <summary>
        /// 指示后高位光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("后高位")]
        [DataMember] 
        public Boolean UpPotocell { get; set; }
        /// <summary>
        /// 指示后低位光电是否被遮挡
        /// </summary>
        [System.ComponentModel.Description("后低位")]
        [DataMember]
        public Boolean DownPotocell { get; set; }
    }
}
