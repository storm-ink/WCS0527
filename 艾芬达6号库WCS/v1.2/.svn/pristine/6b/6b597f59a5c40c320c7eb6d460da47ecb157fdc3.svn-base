
using System;
using System.IO;
using System.Windows.Forms;

namespace Gensong
{
    static class Program
    {
        [STAThread]
        static void Main()
        {
            Application.ThreadException += (sender, e) =>
            {
                StreamWriter sw = File.AppendText("Exception.log"); sw.Write(string.Format("{0}\r\n{1}\r\n{2}\r\n\r\n",
                    "".PadLeft(79, '-'), DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss.fff"), e.Exception.ToString())); sw.Close();
            };

            Application.EnableVisualStyles();
            Application.SetCompatibleTextRenderingDefault(false);
            Application.Run(new frmCHT());
        }
    }

    enum EProject
    {
        /// <summary>默认</summary>
        DF,
        /// <summary>鲁泰_原纱</summary>
        LT_YS,
        /// <summary>鲁泰_色纱</summary>
        LT_SS,
    }
}
