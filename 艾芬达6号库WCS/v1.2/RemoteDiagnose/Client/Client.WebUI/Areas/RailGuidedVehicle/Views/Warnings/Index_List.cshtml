@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Client.RailGuidedVehicle.RailGuidedVehicleWarning>
@{
    Layout = null;
}

<table class="log-entries" id="table" >
<tr>
    <th>Id</th>
    <th>设备名</th>
    <th>任务号</th>
    <th>报警码</th>
    <th>报警描述</th>
    <th>开始时间</th>
    <th>结束时间</th>
    <th>持续时长</th>
</tr>

@foreach (var item in Model)
{
<tr class="">
    <td>@item.Id</td>
    <td>@item.Name</td>
    <td>@item.TaskId</td>
    <td>@item.ErrorCode</td>
    <td>@(item.Alarm==null?"":item.Alarm.Name)</td>
    <td class="longDate">@item.StartTime</td>
    <td class="longDate">@item.EndTime</td>
    <td class="longDate">@(item.TotalMilliseconds!=null?(TimeSpan?)TimeSpan.FromMilliseconds(item.TotalMilliseconds):null)</td>
</tr>    
}
</table>



@if (Model.Count() > 0)
{
    @Html.PagedListPager(this.Model, pageIndex => Url.Action("Index", new { pageIndex }), new PagedListRenderOptions { DisplayItemSliceAndTotal = true, ItemSliceAndTotalFormat = "共 {2} 个" })
}