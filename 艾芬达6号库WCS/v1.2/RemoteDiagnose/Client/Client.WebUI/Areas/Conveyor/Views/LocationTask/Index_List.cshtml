@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Client.Conveyor.LocationTask>

<table>
    <tr>
        <th>
            Id
        </th>
        <th>
            设备名称
        </th>
        <th>
            货位号
        </th>
        <th>
            任务号
        </th>
        <th>
            托盘号
        </th>
        <th>
            X轴可以接收
        </th>
        <th>
            X轴接收完成
        </th>
        <th>
            申请传递
        </th>
        <th>
            准备好
        </th>
        <th>
            Y轴可以接收
        </th>
        <th>
            Y轴接收完成
        </th>
        <th>
            日期
        </th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Id)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.PosNo)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.TaskNo)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.TUID)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Str_Rcv_X)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Fnh_Rcv_X)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Rqs_Snt)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Rcv_Rdy)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Str_Rcv_Y)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Fnh_Rcv_Y)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.LongDate)
        </td>
    </tr>
}

</table>
@if (Model.Count() > 0)
{
    @Html.PagedListPager(this.Model, pageIndex => Url.Action("Index", new { pageIndex }), new PagedList.Mvc.PagedListRenderOptions { DisplayItemSliceAndTotal = true, ItemSliceAndTotalFormat = "共 {2} 个" })
}