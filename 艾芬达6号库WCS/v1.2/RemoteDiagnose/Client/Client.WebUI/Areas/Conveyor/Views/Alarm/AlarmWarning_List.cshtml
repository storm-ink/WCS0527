@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Client.Conveyor.AlarmWarning>

<table>
    <tr>
        <th>
            输送线名称
        </th>
        <th>
            货位号
        </th>
        <th>
            报警类型
        </th>
        <th>开始时间</th>
        <th>结束时间</th>
        <th>持续时长</th>
        <th>
            创建时间
        </th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.PosNo)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.WarningName)
        </td>
        <td>@item.StartTime</td>
        <td>@item.EndTime</td>
        <td>@TimeSpan.FromMilliseconds(item.TotalMilliseconds)</td>
        <td>
            @Html.DisplayFor(modelItem => item.CreatedAt)
        </td>
    </tr>
}

</table>
@if (Model.Count() > 0)
{
    @Html.PagedListPager(this.Model, pageIndex => Url.Action("Index", new { pageIndex }), new PagedList.Mvc.PagedListRenderOptions { DisplayItemSliceAndTotal = true, ItemSliceAndTotalFormat = "共 {2} 个" })
}