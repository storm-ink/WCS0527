<?xml version="1.0" encoding="utf-8"?>
<!--
  有关如何配置 ASP.NET 应用程序的详细信息，请访问
  http://go.microsoft.com/fwlink/?LinkId=169433
  -->

<configuration>
  <configSections>
    <section name="hibernate-configuration" type="NHibernate.Cfg.ConfigurationSectionHandler, NHibernate" />
    <section name="nlog" type="NLog.Config.ConfigSectionHandler, NLog" />
    <section name="remoteDiagnose" type="Client.Cfg.RemoteDiagnoseConfigurationSelectionHandler, Client" />
    <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
      <section name="Client.WebUI.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
    </sectionGroup>
  </configSections>
  <appSettings>
    <add key="webpages:Version" value="2.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="PreserveLoginUrl" value="true" /> 
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />   
    <add key="允许创建数据库表" value="T" />
  </appSettings>

  <remoteDiagnose>
    <deviceDiagnosisDataTypes>
      <add type="Client.RailGuidedVehicle.RailGuidedVehicleDiagnosisData, Client" />
      <add type="Client.SingleForkCrane.StatusDiagnosisData, Client" />
    </deviceDiagnosisDataTypes>
  </remoteDiagnose> 

  <system.web>
    <pages controlRenderingCompatibilityVersion="4.0">
      <namespaces>
        <add namespace="System.Web.Helpers" />
        <add namespace="System.Web.Mvc" />
        <add namespace="System.Web.Mvc.Ajax" />
        <add namespace="System.Web.Mvc.Html" />
        <add namespace="System.Web.Routing" />
        <add namespace="System.Web.WebPages" />
      </namespaces>
    </pages>

    <authentication mode="Forms">
      <forms name=".WMS_AUTH" slidingExpiration="true" timeout="300" loginUrl="/Account/Login" defaultUrl="/" />
    </authentication>
    <compilation targetFramework="4.5" debug="true" />
  </system.web>
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpBinding_IMatedataService" maxBufferSize="65535000" maxReceivedMessageSize="65535000" maxBufferPoolSize="65535000">
          <readerQuotas maxArrayLength="65535000" maxBytesPerRead="65535000" maxStringContentLength="65535000" maxNameTableCharCount="65535000" maxDepth="65535000" />
        </binding>
      </basicHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://10.12.96.58:9991/WcsLogsDiagnoseMatedataServiceProxy" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatedataService" contract="WcsLogsDiagnoseMatedataService.IMatedataService" name="BasicHttpBinding_IMatedataService" />
    
      <endpoint address="http://10.12.96.58:9991/SingleForkCraneStatusDiagnoseMatedataServiceProxy" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatedataService" contract="SingleForkCraneStatusDiagnoseMatedataService.IMatedataService" name="BasicHttpBinding_IMatedataService" />
      <endpoint address="http://10.12.96.58:9991/RailGuidedVehicleDataDiagnoseMatedataServiceProxy" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatedataService" contract="RailGuidedVehicleDataDiagnoseMatedataService.IMatedataService" name="BasicHttpBinding_IMatedataService1" />
      
      <endpoint address="http://10.12.96.58:9991/CraneServiceProxy" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatedataService" contract="CraneDeviceServiceProxy.ICraneService" name="BasicHttpBinding_ICraneService" />

      <endpoint address="http://10.12.96.58:9991/ConveyorServiceProxy" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatedataService" contract="ConveyorDeviceServiceProxy.IConveyorService" name="BasicHttpBinding_IConveyorService" />


      <endpoint address="http://10.12.96.58:9991/RailGuidedVehicleDeviceServiceProxy" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatedataService" contract="RailGuidedVehicleDeviceServiceProxy.IRailGuidedVehicleService" name="BasicHttpBinding_IRailGuidedVehicleService" />


      <endpoint address="http://10.12.96.58:9991/ConveyorDataDiagnoseMatedataServiceProxy" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IMatedataService" contract="ConveyorDataDiagnoseMatedataService.IMatedataService" name="BasicHttpBinding_IMatedataService2" />
    </client>
  </system.serviceModel>
  <system.web.extensions>
    <scripting>
      <webServices>
        <jsonSerialization maxJsonLength="10240000" /> 
      </webServices>
    </scripting>
  </system.web.extensions>
  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    
    <modules runAllManagedModulesForAllRequests="true" />
    
  <handlers><remove name="ExtensionlessUrlHandler-ISAPI-4.0_32bit" /><remove name="ExtensionlessUrlHandler-ISAPI-4.0_64bit" /><remove name="ExtensionlessUrlHandler-Integrated-4.0" /><add name="ExtensionlessUrlHandler-ISAPI-4.0_32bit" path="*." verb="GET,HEAD,POST,DEBUG,PUT,DELETE,PATCH,OPTIONS" modules="IsapiModule" scriptProcessor="%windir%\Microsoft.NET\Framework\v4.0.30319\aspnet_isapi.dll" preCondition="classicMode,runtimeVersionv4.0,bitness32" responseBufferLimit="0" /><add name="ExtensionlessUrlHandler-ISAPI-4.0_64bit" path="*." verb="GET,HEAD,POST,DEBUG,PUT,DELETE,PATCH,OPTIONS" modules="IsapiModule" scriptProcessor="%windir%\Microsoft.NET\Framework64\v4.0.30319\aspnet_isapi.dll" preCondition="classicMode,runtimeVersionv4.0,bitness64" responseBufferLimit="0" /><add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="GET,HEAD,POST,DEBUG,PUT,DELETE,PATCH,OPTIONS" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" /></handlers></system.webServer>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="NLog" publicKeyToken="5120e14c03d0593c" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-3.1.0.0" newVersion="3.1.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
  <hibernate-configuration xmlns="urn:nhibernate-configuration-2.2">
    <session-factory name="wcs">
      <property name="connection.driver_class">NHibernate.Driver.SqlClientDriver</property>
      <property name="connection.connection_string">Data Source=.;Initial Catalog=RemoteDiagnose;User Id=sa;Password=gen@song123;</property>
      <property name="dialect">NHibernate.Dialect.MsSql2008Dialect</property>
      <property name="adonet.batch_size">50</property>
      <property name="query.substitutions">true 1, false 0</property>
      <property name="prepare_sql">true</property>
      <property name="show_sql">false</property>
      <mapping assembly="Spiral.Base" />
      <mapping assembly="Client" />
    </session-factory>
  </hibernate-configuration>
  <nlog throwExceptions="true">
    <targets async="true">
      <target name="database" type="Database" connectionString="Data Source=.;Initial Catalog=wcs_logs;User Id=sa;Password=gen@song123;Enlist=False" commandText="INSERT INTO [dbo].[Logs] ([LongDate],[Level],[ThreadId] ,[Logger],[Message],[Exception],[Sender],[MachineName],[ProcessName])               VALUES                (@LongDate ,@Level ,@ThreadId ,@Logger ,@Message ,@Exception,@Sender,@MachineName, @ProcessName)">
        <parameter name="@LongDate" layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff}" />
        <parameter name="@Level" layout="${level}" />
        <parameter name="@MachineName" layout="${machineName}" />
        <parameter name="@ProcessName" layout="${processname}" />
        <parameter name="@ProcessId" layout="${processid}" />
        <parameter name="@ThreadId" layout="${threadid}" />
        <parameter name="@Logger" layout="${logger}" />
        <parameter name="@Message" layout="${message}" />
        <parameter name="@Exception" layout="${exception:format=tostring}" />
        <parameter name="@Sender" layout="${event-context:sender}" />
      </target>
    </targets>
    <rules>
      <logger name="*" minlevel="Trace" writeTo="database" />
    </rules>
  </nlog>
  <applicationSettings>
    <Client.WebUI.Properties.Settings>
      <setting name="WorkStartTime" serializeAs="String">
        <value>08:00:00</value>
      </setting>
      <setting name="OffDutyTime" serializeAs="String">
        <value>17:00:00</value>
      </setting>
    </Client.WebUI.Properties.Settings>
  </applicationSettings>
</configuration>
