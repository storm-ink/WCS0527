@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<Client.Logs.WcsLogDiagnosisData>
@{
    Layout = null;
}

<table class="log-entries" id="table" >
<tr>
    <th>Id</th>
    <th>时间</th>
    <th>日志名</th>
    <th>来源</th>
    <th>级别</th>
    <th>线程</th>
    <th>用户</th>
    <th>任务号</th>
    <th>设备任务</th>
    <th>消息</th>
    <th>&nbsp;</th>
  
</tr>

@foreach (var item in Model)
{
<tr class="@item.Level.ToLower()">
    <td>@item.LogId</td>
    <td class="longDate">@item.LongDate.ToString("yyyy-MM-dd HH:mm:ss.fff")</td>
    <td>@item.Logger</td>
    <td>@item.Sender</td>
    <td>@item.Level</td>
    <td class="threadId">@item.ThreadId</td>  
    <td>@item.UserName</td>
    <td>@item.TaskCode</td>
    <td>@item.EquipmentTaskId</td>
    <td>@renderMessage(item.Message)</td>
    <td>
    @Html.ActionLink("详细", "Details", new { id = @item.Id }, new { target="_blank" })
    <a href="/WcsLogs?mode=bythread&ThreadId=@(item.ThreadId)&DateMin=@(item.LongDate.ToString("yyyy-MM-dd HH:mm:ss"))" class="search" target="_blank">跟踪</a>
    </td>
</tr>    
}
</table>



@if (Model.Count() > 0)
{
    @Html.PagedListPager(this.Model, pageIndex => Url.Action("Index", new { pageIndex }), new PagedListRenderOptions { DisplayItemSliceAndTotal = true, ItemSliceAndTotalFormat = "共 {2} 个" })
}
@helper renderMessage(String msg)
    {
        
        int len;
        if (int.TryParse(Request["notsplit"], out len) && len>0)
        {
            if (msg.Length <= len)
            {
                <pre>@msg</pre>
            }
            else
            {
                <pre>@msg.Substring(0, len) ...</pre>
            }
        }else{
             <pre>@msg</pre>
        }
    }